+++ b/src/components/BatteryLockSection.tsx
@@ -0,0 +1,104 @@
+/**
+ * BatteryLockSection.tsx
+ * Settings UI for the two-tier battery protection.
+ * Self-contained; mounted in AdvancedTab.
+ *
+ * Thresholds:  warn (y) > freeze (x),  release (Z) > freeze (x),  step (a) >= 1
+ */
+
+import React, { useState, useEffect } from 'react';
+import SettingsSection from './settings/SettingsSection';
+import SettingsSwitch from './settings/SettingsSwitch';
+import SettingsInput from './settings/SettingsInput';
+import { StorageService } from '../utils/storage';
+
+export const BatteryLockSection: React.FC = () => {
+  const [enabled, setEnabled] = useState(false);
+  const [freeze, setFreeze] = useState('5');
+  const [warn, setWarn] = useState('20');
+  const [release, setRelease] = useState('50');
+  const [step, setStep] = useState('1');
+  const [message, setMessage] = useState('');
+
+  useEffect(() => {
+    (async () => {
+      setEnabled(await StorageService.getBatteryLockEnabled());
+      setFreeze(String(await StorageService.getBatteryLockThreshold()));
+      setWarn(String(await StorageService.getBatteryWarnThreshold()));
+      setRelease(String(await StorageService.getBatteryReleaseThreshold()));
+      setStep(String(await StorageService.getBatteryWarnStep()));
+      setMessage(await StorageService.getBatteryLockMessage());
+    })();
+  }, []);
+
+  const onEnabledChange = async (v: boolean) => {
+    setEnabled(v);
+    await StorageService.saveBatteryLockEnabled(v);
+  };
+
+  const clampSave = async (
+    text: string,
+    setter: (s: string) => void,
+    save: (n: number) => Promise<void>,
+    min: number,
+    max: number,
+  ) => {
+    setter(text);
+    const n = parseInt(text, 10);
+    if (!isNaN(n) && n >= min && n <= max) { await save(n); }
+  };
+
+  return (
+    <SettingsSection title="Battery Protection">
+      <SettingsSwitch
+        label="Low-battery warning & lock"
+        hint="Shows an acknowledgeable warning as the battery gets low, then a full-screen lock at the critical level. Clears when charged."
+        value={enabled}
+        onValueChange={onEnabledChange}
+      />
+      {enabled && (
+        <>
+          <SettingsInput
+            label="Warn at (%)  —  y"
+            hint="Amber warning appears at or below this level (must be above the freeze level)."
+            value={warn}
+            onChangeText={(t) => clampSave(t, setWarn, StorageService.saveBatteryWarnThreshold, 2, 95)}
+            placeholder="20"
+            keyboardType="numeric"
+          />
+          <SettingsInput
+            label="Re-warn every (%)  —  a"
+            hint="After Acknowledge, the warning returns each time the battery drops this many percent."
+            value={step}
+            onChangeText={(t) => clampSave(t, setStep, StorageService.saveBatteryWarnStep, 1, 50)}
+            placeholder="1"
+            keyboardType="numeric"
+          />
+          <SettingsInput
+            label="Freeze at (%)  —  x"
+            hint="Full-screen lock triggers at or below this level. Freeze always wins below this."
+            value={freeze}
+            onChangeText={(t) => clampSave(t, setFreeze, StorageService.saveBatteryLockThreshold, 1, 90)}
+            placeholder="5"
+            keyboardType="numeric"
+          />
+          <SettingsInput
+            label="Release at (%)  —  Z"
+            hint="Once charged to this level, the freeze is cleared for the cycle. Unplugging before reaching it brings the freeze back."
+            value={release}
+            onChangeText={(t) => clampSave(t, setRelease, StorageService.saveBatteryReleaseThreshold, 2, 100)}
+            placeholder="50"
+            keyboardType="numeric"
+          />
+          <SettingsInput
+            label="Custom message (optional)"
+            hint="Shown on both the warning and freeze screens. Leave empty for defaults."
+            value={message}
+            onChangeText={(t) => { setMessage(t); StorageService.saveBatteryLockMessage(t); }}
+            placeholder="Please charge this device"
+          />
+        </>
+      )}
+    </SettingsSection>
+  );
+};
