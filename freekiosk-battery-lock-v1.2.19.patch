diff --git a/src/components/BatteryLockOverlay.tsx b/src/components/BatteryLockOverlay.tsx
new file mode 100644
index 0000000..92000d1
--- /dev/null
+++ b/src/components/BatteryLockOverlay.tsx
@@ -0,0 +1,285 @@
+/**
+ * BatteryLockOverlay.tsx
+ *
+ * Two-tier low-battery protection, rendered above all kiosk content:
+ *
+ *  WARNING tier (amber, acknowledgeable):
+ *    - shows while discharging and (freeze < level <= warn)
+ *    - dismissed only via the Acknowledge button
+ *    - after acknowledging at level L, stays gone until level drops to (L - step),
+ *      then re-appears; flat battery stays dismissed
+ *    - charger connected clears it and resets the acknowledge tracker
+ *
+ *  FREEZE tier (red, hard):  single "armed" latch
+ *    - arms when level <= freeze
+ *    - disarms when level >= release (Z)
+ *    - overlay visible when armed AND NOT (charging AND level > freeze)
+ *      => plugging in hides it while it charges above the freeze level;
+ *         unplugging below Z brings it back; reaching Z clears it for the cycle
+ *
+ * All icons are drawn with plain Views (no emoji, no icon font) so they render
+ * identically on every device.
+ */
+
+import React, { useState, useEffect, useRef } from 'react';
+import {
+  Modal,
+  View,
+  Text,
+  StyleSheet,
+  TouchableOpacity,
+  Animated,
+  Easing,
+  NativeModules,
+  AppState,
+} from 'react-native';
+import { StorageService } from '../utils/storage';
+
+const { SystemInfoModule } = NativeModules;
+
+const POLL_INTERVAL_MS = 15000;
+
+// ---- Drawn battery icon (no emoji / no icon font) --------------------------
+const BatteryIcon: React.FC<{ color: string; fillRatio: number }> = ({
+  color,
+  fillRatio,
+}) => {
+  const bodyW = 120;
+  const innerW = Math.max(6, Math.round((bodyW - 16) * Math.min(1, Math.max(0, fillRatio))));
+  return (
+    <View style={styles.iconRow}>
+      <View style={[styles.batteryBody, { borderColor: color }]}>
+        <View style={[styles.batteryFill, { width: innerW, backgroundColor: color }]} />
+      </View>
+      <View style={[styles.batteryCap, { backgroundColor: color }]} />
+    </View>
+  );
+};
+
+type Settings = {
+  enabled: boolean;
+  freeze: number;   // x
+  warn: number;     // y
+  release: number;  // Z
+  step: number;     // a
+  message: string;
+};
+
+const BatteryLockOverlay: React.FC = () => {
+  const [tier, setTier] = useState<'none' | 'warn' | 'freeze'>('none');
+  const [level, setLevel] = useState<number | null>(null);
+  const [charging, setCharging] = useState(false);
+  const [message, setMessage] = useState('');
+
+  // persistent latches (refs so the poll closure always sees the latest)
+  const freezeArmed = useRef(false);
+  const lastAckLevel = useRef<number | null>(null); // level at which user last acknowledged
+  const warnDismissedAt = useRef<number | null>(null);
+  const settingsRef = useRef<Settings>({
+    enabled: false, freeze: 5, warn: 20, release: 50, step: 1, message: '',
+  });
+
+  // flashing pulse for the warning tier (gentle opacity, not a redraw storm)
+  const pulse = useRef(new Animated.Value(1)).current;
+  const pulseLoop = useRef<Animated.CompositeAnimation | null>(null);
+
+  const startPulse = () => {
+    if (pulseLoop.current) { return; }
+    pulseLoop.current = Animated.loop(
+      Animated.sequence([
+        Animated.timing(pulse, { toValue: 0.35, duration: 600, easing: Easing.inOut(Easing.ease), useNativeDriver: true }),
+        Animated.timing(pulse, { toValue: 1, duration: 600, easing: Easing.inOut(Easing.ease), useNativeDriver: true }),
+      ]),
+    );
+    pulseLoop.current.start();
+  };
+  const stopPulse = () => {
+    pulseLoop.current?.stop();
+    pulseLoop.current = null;
+    pulse.setValue(1);
+  };
+
+  const evaluate = (lvl: number, isCharging: boolean) => {
+    const s = settingsRef.current;
+
+    // ---- FREEZE latch ----
+    if (lvl <= s.freeze) { freezeArmed.current = true; }
+    if (lvl >= s.release) { freezeArmed.current = false; }
+    const freezeVisible = freezeArmed.current && !(isCharging && lvl > s.freeze);
+
+    if (freezeVisible) {
+      // freeze wins over everything; also clear any warning bookkeeping
+      warnDismissedAt.current = null;
+      lastAckLevel.current = null;
+      return 'freeze' as const;
+    }
+
+    // ---- WARNING tier ---- (only while discharging, above freeze, at/below warn)
+    if (isCharging) {
+      // charger clears the warning and resets the acknowledge tracker
+      lastAckLevel.current = null;
+      warnDismissedAt.current = null;
+      return 'none' as const;
+    }
+
+    if (lvl > s.freeze && lvl <= s.warn) {
+      // Has the user acknowledged at this level or higher, with no qualifying drop since?
+      const ack = lastAckLevel.current;
+      if (ack !== null && lvl > ack - s.step) {
+        // not yet dropped a full step below the last acknowledged level
+        return 'none' as const;
+      }
+      return 'warn' as const;
+    }
+
+    return 'none' as const;
+  };
+
+  useEffect(() => {
+    let mounted = true;
+    let interval: ReturnType<typeof setInterval> | null = null;
+
+    const check = async () => {
+      try {
+        const [enabled, freeze, warn, release, step, msg] = await Promise.all([
+          StorageService.getBatteryLockEnabled(),
+          StorageService.getBatteryLockThreshold(),
+          StorageService.getBatteryWarnThreshold(),
+          StorageService.getBatteryReleaseThreshold(),
+          StorageService.getBatteryWarnStep(),
+          StorageService.getBatteryLockMessage(),
+        ]);
+        settingsRef.current = { enabled, freeze, warn, release, step, message: msg };
+        if (mounted) { setMessage(msg); }
+
+        if (!enabled) {
+          freezeArmed.current = false;
+          lastAckLevel.current = null;
+          warnDismissedAt.current = null;
+          if (mounted) { setTier('none'); }
+          return;
+        }
+        if (!SystemInfoModule?.getSystemInfo) { return; }
+
+        const info = await SystemInfoModule.getSystemInfo();
+        const batt = info?.battery;
+        if (!batt || typeof batt.level !== 'number') { return; }
+
+        const lvl = Math.round(batt.level);
+        const isCharging = !!batt.isCharging;
+        const nextTier = evaluate(lvl, isCharging);
+
+        if (mounted) {
+          setLevel(lvl);
+          setCharging(isCharging);
+          setTier(nextTier);
+        }
+      } catch (e) {
+        console.warn('[BatteryLock] check error', e);
+      }
+    };
+
+    check();
+    interval = setInterval(check, POLL_INTERVAL_MS);
+    const sub = AppState.addEventListener('change', (state) => {
+      if (state === 'active') { check(); }
+    });
+
+    return () => {
+      mounted = false;
+      if (interval) { clearInterval(interval); }
+      sub.remove();
+      stopPulse();
+    };
+  }, []);
+
+  // drive the pulse animation from tier
+  useEffect(() => {
+    if (tier === 'warn') { startPulse(); } else { stopPulse(); }
+  }, [tier]);
+
+  const onAcknowledge = () => {
+    if (level !== null) { lastAckLevel.current = level; }
+    setTier('none');
+  };
+
+  if (tier === 'none') { return null; }
+
+  if (tier === 'warn') {
+    return (
+      <Modal visible transparent animationType="fade" statusBarTranslucent hardwareAccelerated
+        onRequestClose={() => {}}>
+        <View style={styles.warnBackdrop}>
+          <Animated.View style={[styles.warnCard, { opacity: pulse }]}>
+            <BatteryIcon color="#7a4a00" fillRatio={level ? level / 100 : 0.15} />
+            <Text style={styles.warnTitle}>Battery running low</Text>
+            <Text style={styles.warnSubtitle}>
+              {message && message.length > 0 ? message : 'Please put this device on charge soon.'}
+            </Text>
+            <Text style={styles.warnLevel}>{level !== null ? `${level}%` : ''}</Text>
+          </Animated.View>
+          <TouchableOpacity style={styles.ackButton} activeOpacity={0.8} onPress={onAcknowledge}>
+            <Text style={styles.ackButtonText}>Acknowledge</Text>
+          </TouchableOpacity>
+        </View>
+      </Modal>
+    );
+  }
+
+  // freeze
+  return (
+    <Modal visible animationType="fade" statusBarTranslucent hardwareAccelerated
+      onRequestClose={() => {}}>
+      <View style={styles.freezeContainer}>
+        <BatteryIcon color="#ffffff" fillRatio={level ? level / 100 : 0.05} />
+        <Text style={styles.freezeTitle}>Battery critically low</Text>
+        <Text style={styles.freezeSubtitle}>
+          {message && message.length > 0 ? message : 'Please connect the charger to continue.'}
+        </Text>
+        <Text style={styles.freezeLevel}>
+          {level !== null ? `${level}%` : ''}{charging ? '  charging…' : ''}
+        </Text>
+      </View>
+    </Modal>
+  );
+};
+
+const styles = StyleSheet.create({
+  // battery icon
+  iconRow: { flexDirection: 'row', alignItems: 'center', marginBottom: 28 },
+  batteryBody: {
+    width: 120, height: 56, borderWidth: 5, borderRadius: 8,
+    padding: 5, justifyContent: 'center',
+  },
+  batteryFill: { height: '100%', borderRadius: 3 },
+  batteryCap: { width: 8, height: 24, borderTopRightRadius: 3, borderBottomRightRadius: 3, marginLeft: 2 },
+
+  // warning tier
+  warnBackdrop: {
+    flex: 1, backgroundColor: 'rgba(0,0,0,0.55)',
+    alignItems: 'center', justifyContent: 'center', paddingHorizontal: 28,
+  },
+  warnCard: {
+    backgroundColor: '#FFC107', borderRadius: 20, paddingVertical: 32, paddingHorizontal: 28,
+    alignItems: 'center', width: '100%', maxWidth: 460,
+  },
+  warnTitle: { color: '#3d2c00', fontSize: 24, fontWeight: '800', textAlign: 'center', marginBottom: 8 },
+  warnSubtitle: { color: '#5a4200', fontSize: 16, textAlign: 'center', marginBottom: 14 },
+  warnLevel: { color: '#3d2c00', fontSize: 30, fontWeight: '800' },
+  ackButton: {
+    marginTop: 28, backgroundColor: '#212121', paddingVertical: 16, paddingHorizontal: 48,
+    borderRadius: 14,
+  },
+  ackButtonText: { color: '#fff', fontSize: 18, fontWeight: '700' },
+
+  // freeze tier
+  freezeContainer: {
+    flex: 1, backgroundColor: '#B00020',
+    alignItems: 'center', justifyContent: 'center', paddingHorizontal: 32,
+  },
+  freezeTitle: { color: '#fff', fontSize: 28, fontWeight: '800', textAlign: 'center', marginBottom: 10 },
+  freezeSubtitle: { color: '#FFD6DB', fontSize: 18, textAlign: 'center', marginBottom: 28 },
+  freezeLevel: { color: '#fff', fontSize: 24, fontWeight: '700' },
+});
+
+export default BatteryLockOverlay;
