+/**
+ * BatteryLockOverlay.tsx
+ * Full-screen blocking overlay shown when battery drops below a configured
+ * threshold while not charging. Self-contained: reads its own settings from
+ * storage and polls battery state via SystemInfoModule.
+ *
+ * Unlock conditions (hysteresis to avoid flapping at the threshold):
+ *  - charger connected, OR
+ *  - battery level >= threshold + RESUME_HYSTERESIS
+ */
+
+import React, { useState, useEffect, useRef } from 'react';
+import {
+  Modal,
+  View,
+  Text,
+  StyleSheet,
+  NativeModules,
+  AppState,
+} from 'react-native';
+import { StorageService } from '../utils/storage';
+
+const { SystemInfoModule } = NativeModules;
+
+const POLL_INTERVAL_MS = 15000;
+const RESUME_HYSTERESIS = 3; // unlock at threshold + 3% when discharging
+
+const BatteryLockOverlay: React.FC = () => {
+  const [locked, setLocked] = useState(false);
+  const [level, setLevel] = useState<number | null>(null);
+  const [charging, setCharging] = useState(false);
+  const [message, setMessage] = useState('');
+  const settingsRef = useRef({ enabled: false, threshold: 5 });
+  const lockedRef = useRef(false);
+
+  useEffect(() => {
+    let mounted = true;
+    let interval: ReturnType<typeof setInterval> | null = null;
+
+    const check = async () => {
+      try {
+        // Re-read settings each cycle so ADB/MDM-pushed config changes
+        // take effect without an app restart.
+        const [enabled, threshold, msg] = await Promise.all([
+          StorageService.getBatteryLockEnabled(),
+          StorageService.getBatteryLockThreshold(),
+          StorageService.getBatteryLockMessage(),
+        ]);
+        settingsRef.current = { enabled, threshold };
+        if (mounted) {
+          setMessage(msg);
+        }
+
+        if (!enabled) {
+          if (mounted && lockedRef.current) {
+            lockedRef.current = false;
+            setLocked(false);
+          }
+          return;
+        }
+
+        if (!SystemInfoModule?.getSystemInfo) {
+          return;
+        }
+        const info = await SystemInfoModule.getSystemInfo();
+        const batt = info?.battery;
+        if (!batt || typeof batt.level !== 'number') {
+          return;
+        }
+
+        const isCharging = !!batt.isCharging;
+        if (mounted) {
+          setLevel(batt.level);
+          setCharging(isCharging);
+        }
+
+        let shouldLock: boolean;
+        if (lockedRef.current) {
+          // Already locked: release on charger, or with hysteresis margin
+          shouldLock =
+            !isCharging && batt.level < threshold + RESUME_HYSTERESIS;
+        } else {
+          shouldLock = !isCharging && batt.level <= threshold;
+        }
+
+        if (mounted && shouldLock !== lockedRef.current) {
+          lockedRef.current = shouldLock;
+          setLocked(shouldLock);
+          console.log(
+            `[BatteryLock] ${shouldLock ? 'LOCKED' : 'released'} at ${
+              batt.level
+            }% (threshold ${threshold}%, charging=${isCharging})`,
+          );
+        }
+      } catch (e) {
+        console.warn('[BatteryLock] check error', e);
+      }
+    };
+
+    check();
+    interval = setInterval(check, POLL_INTERVAL_MS);
+
+    // Re-check immediately when app returns to foreground
+    const sub = AppState.addEventListener('change', (state) => {
+      if (state === 'active') {
+        check();
+      }
+    });
+
+    return () => {
+      mounted = false;
+      if (interval) {
+        clearInterval(interval);
+      }
+      sub.remove();
+    };
+  }, []);
+
+  if (!locked) {
+    return null;
+  }
+
+  return (
+    <Modal
+      visible
+      animationType="fade"
+      statusBarTranslucent
+      hardwareAccelerated
+      onRequestClose={() => {
+        /* not dismissible */
+      }}
+    >
+      <View style={styles.container}>
+        <Text style={styles.icon}>🪫</Text>
+        <Text style={styles.title}>Battery critically low</Text>
+        <Text style={styles.subtitle}>
+          {message && message.length > 0
+            ? message
+            : 'Please connect the charger to continue'}
+        </Text>
+        <Text style={styles.level}>
+          {level !== null ? `${Math.round(level)}%` : ''}
+          {charging ? '  ⚡ charging…' : ''}
+        </Text>
+      </View>
+    </Modal>
+  );
+};
+
+const styles = StyleSheet.create({
+  container: {
+    flex: 1,
+    backgroundColor: '#B00020',
+    alignItems: 'center',
+    justifyContent: 'center',
+    paddingHorizontal: 32,
+  },
+  icon: {
+    fontSize: 72,
+    marginBottom: 24,
+  },
+  title: {
+    color: '#FFFFFF',
+    fontSize: 28,
+    fontWeight: '700',
+    textAlign: 'center',
+    marginBottom: 12,
+  },
+  subtitle: {
+    color: '#FFD6DB',
+    fontSize: 18,
+    textAlign: 'center',
+    marginBottom: 32,
+  },
+  level: {
+    color: '#FFFFFF',
+    fontSize: 22,
+    fontWeight: '600',
+  },
+});
+
+export default BatteryLockOverlay;
