+/**
+ * BatteryLockSection.tsx
+ * Settings section for the low-battery lock feature.
+ * Self-contained (reads/writes its own settings), mounted in AdvancedTab.
+ */
+
+import React, { useState, useEffect } from 'react';
+import SettingsSection from './settings/SettingsSection';
+import SettingsSwitch from './settings/SettingsSwitch';
+import SettingsInput from './settings/SettingsInput';
+import { StorageService } from '../utils/storage';
+
+export const BatteryLockSection: React.FC = () => {
+  const [enabled, setEnabled] = useState(false);
+  const [threshold, setThreshold] = useState('5');
+  const [message, setMessage] = useState('');
+
+  useEffect(() => {
+    (async () => {
+      setEnabled(await StorageService.getBatteryLockEnabled());
+      setThreshold(String(await StorageService.getBatteryLockThreshold()));
+      setMessage(await StorageService.getBatteryLockMessage());
+    })();
+  }, []);
+
+  const onEnabledChange = async (value: boolean) => {
+    setEnabled(value);
+    await StorageService.saveBatteryLockEnabled(value);
+  };
+
+  const onThresholdChange = async (text: string) => {
+    setThreshold(text);
+    const n = parseInt(text, 10);
+    if (!isNaN(n) && n >= 1 && n <= 90) {
+      await StorageService.saveBatteryLockThreshold(n);
+    }
+  };
+
+  const onMessageChange = async (text: string) => {
+    setMessage(text);
+    await StorageService.saveBatteryLockMessage(text);
+  };
+
+  return (
+    <SettingsSection title="Battery Lock">
+      <SettingsSwitch
+        label="Lock kiosk on low battery"
+        hint="Shows a full-screen recharge prompt when the battery drops below the threshold while not charging. Clears automatically when a charger is connected."
+        value={enabled}
+        onValueChange={onEnabledChange}
+      />
+      {enabled && (
+        <>
+          <SettingsInput
+            label="Threshold (%)"
+            hint="1–90. Lock triggers at or below this level."
+            value={threshold}
+            onChangeText={onThresholdChange}
+            placeholder="5"
+            keyboardType="numeric"
+          />
+          <SettingsInput
+            label="Custom message (optional)"
+            hint="Shown on the lock screen. Leave empty for the default."
+            value={message}
+            onChangeText={onMessageChange}
+            placeholder="Please connect the charger to continue"
+          />
+        </>
+      )}
+    </SettingsSection>
+  );
+};
