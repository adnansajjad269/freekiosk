+  const getWakeLockOverrideScript = (): string => {
+    return keepScreenOn === false ? WAKE_LOCK_NEUTRALIZE_JS : '';
+  };
+
+  // #1 — Apply the wake-lock override live when the setting toggles (or a pushed
+  // config changes it), without waiting for a page reload. On the current page's
