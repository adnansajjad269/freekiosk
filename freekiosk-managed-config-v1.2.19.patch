+  webview_zoom_level: { get: StorageService.getWebViewZoomLevel, set: StorageService.saveWebViewZoomLevel },
+  mqtt_port: { get: StorageService.getMqttPort, set: StorageService.saveMqttPort },
+  mqtt_status_interval: { get: StorageService.getMqttStatusInterval, set: StorageService.saveMqttStatusInterval },
+  media_player_image_duration: { get: StorageService.getMediaPlayerImageDuration, set: StorageService.saveMediaPlayerImageDuration },
+  media_player_transition_duration: { get: StorageService.getMediaPlayerTransitionDuration, set: StorageService.saveMediaPlayerTransitionDuration },
+};
+
+// Array / object-array fields (convention 2 + 4). Typed loosely as any[]
+// since each setter/getter expects its own element shape; the console-authored
+// JSON is responsible for matching those shapes. Equality is JSON.stringify-
+// based (order-sensitive) — see applyFieldGroup's arrayEquals.
+const ARRAY_FIELDS: FieldTable<any[]> = {
+  url_rotation_list: { get: StorageService.getUrlRotationList, set: StorageService.saveUrlRotationList },
+  url_planner_events: { get: StorageService.getUrlPlannerEvents, set: StorageService.saveUrlPlannerEvents },
+  blocking_overlays_regions: { get: StorageService.getBlockingOverlaysRegions, set: StorageService.saveBlockingOverlaysRegions },
+  screen_scheduler_rules: { get: StorageService.getScreenSchedulerRules, set: StorageService.saveScreenSchedulerRules },
+  url_filter_list: { get: StorageService.getUrlFilterList, set: StorageService.saveUrlFilterList },
+  managed_apps: { get: StorageService.getManagedApps, set: StorageService.saveManagedApps },
+  screensaver_video_items: { get: StorageService.getScreensaverVideoItems, set: StorageService.saveScreensaverVideoItems },
+  media_player_items: { get: StorageService.getMediaPlayerItems, set: StorageService.saveMediaPlayerItems },
+  dashboard_tiles: { get: StorageService.getDashboardTiles, set: StorageService.saveDashboardTiles },
+};
+
+// ---- push-shape helpers (conventions 7-8) -----------------------------------
+
+// Keys that are legitimate at the top level of the restrictions bundle but are
+// not settings fields themselves.
+const RESERVED_KEYS = new Set(['config_version', 'config_fields', 'kiosk_pin', 'kiosk_pin_label']);
+
+const KNOWN_FIELD_KEYS = new Set([
+  ...Object.keys(BOOL_FIELDS),
+  ...Object.keys(STRING_FIELDS),
+  ...Object.keys(NUMBER_FIELDS),
+  ...Object.keys(ARRAY_FIELDS),
+]);
+
+/**
+ * Stable fingerprint of the config payload (sorted keys, PIN siblings
+ * excluded — a per-device PIN rotation legitimately changes the bundle
+ * without a config_version bump and must not look like an unbumped edit).
+ */
+function computeFingerprint(restrictions: Record<string, unknown>): string {
+  const keys = Object.keys(restrictions)
+    .filter((k) => k !== 'kiosk_pin' && k !== 'kiosk_pin_label')
+    .sort();
+  const obj: Record<string, unknown> = {};
+  for (const k of keys) obj[k] = restrictions[k];
+  try {
+    return JSON.stringify(obj);
+  } catch {
+    return keys.join(',');
+  }
+}
+
+/** Parse the optional config_fields manifest: comma-separated string or string array. */
+function parseConfigFields(v: unknown): string[] | undefined {
+  if (typeof v === 'string') return v.split(',').map((s) => s.trim()).filter(Boolean);
+  if (Array.isArray(v)) return v.map((s) => String(s).trim()).filter(Boolean);
+  return undefined;
+}
+
+/** Report the per-push status to the console's custom1 column. */
+async function reportConfigAck(
+  native: ManagedConfigNative | undefined,
+  version: string,
+  status: 'Success' | 'Error',
+): Promise<void> {
+  if (!native) return;
+  const ackValue = `Config #${version} ${status}`;
+  try {
+    await native.reportCustom(1, ackValue);
+    console.log(`[ManagedConfig] reported config ack custom1="${ackValue}"`);
+  } catch (e) {
+    console.warn('[ManagedConfig] config_version ack (custom1) failed:', e);
+  }
+}
+
+// ---- PIN (convention 3) ----------------------------------------------------
+
+/**
+ * Apply a top-level kiosk_pin sibling attribute. Runs on EVERY emission,
+ * ungated by config_version. Idempotent: only writes (and acks) on a real
+ * change. Never reports anything derived from the PIN — the ack is the
+ * admin-chosen kiosk_pin_label (or a timestamp fallback).
+ *
+ * Returns true only if the PIN was actually changed.
+ */
+export async function applyPin(
+  restrictions: Record<string, unknown>,
+  native: ManagedConfigNative | undefined,
+): Promise<boolean> {
+  const rawPin = restrictions.kiosk_pin;
+  if (rawPin === undefined || rawPin === null) return false;
+
+  const pin = String(rawPin).padStart(KIOSK_PIN_LENGTH, '0');
+  const unchanged = await securePinMatches(pin);
+  if (unchanged) {
+    console.log('[ManagedConfig] kiosk_pin present but unchanged; skipping');
+    return false;
+  }
+
+  await saveSecurePin(pin);
+
+  // Ack token: the admin-pushed kiosk_pin_label if present, otherwise a
+  // human-readable local "applied at" datetime (never raw epoch ms, and never
+  // anything derived from the PIN itself).
+  const label = restrictions.kiosk_pin_label;
+  const ackValue = label != null ? String(label) : formatLocalDateTime(new Date());
+  try {
+    await native?.reportCustom(2, ackValue);
+    console.log(`[ManagedConfig] PIN updated, reported ack custom2=${ackValue}`);
+  } catch (e) {
+    console.warn('[ManagedConfig] PIN ack (custom2) failed:', e);
+  }
+  return true;
+}
+
+/** Local time as "YYYY-MM-DD HH:mm" — sortable in the console's custom2 column. */
+function formatLocalDateTime(d: Date): string {
+  const pad = (n: number) => String(n).padStart(2, '0');
+  return (
+    `${d.getFullYear()}-${pad(d.getMonth() + 1)}-${pad(d.getDate())} ` +
+    `${pad(d.getHours())}:${pad(d.getMinutes())}`
+  );
+}
+
+// ---- bulk apply (version-gated, per-field diffed) --------------------------
+
+type FieldOutcome =
+  | { key: string; outcome: 'applied'; value: unknown }
+  | { key: string; outcome: 'skipped'; value: unknown }
+  | { key: string; outcome: 'error'; reason: string };
+
+export interface BulkApplyResult {
+  applied: { key: string; value: unknown }[];
+  skipped: { key: string; value: unknown }[];
+  errors: { key: string; reason: string }[];
+}
+
+/**
+ * Apply one field group: for every key present in `payload` that this table
+ * knows about, coerce the incoming value, compare it against what's
+ * currently stored, and only write on a genuine difference. A coercion
+ * failure or a thrown write is recorded as an error for THAT KEY ONLY — it
+ * never aborts the rest of the group or the other groups (convention 6: one
+ * bad or unchanged field never discards the whole push).
+ */
+async function applyFieldGroup<T>(
+  payload: Record<string, unknown>,
+  table: FieldTable<T>,
+  coerce: (raw: unknown) => { value: T } | { error: string },
+  equals: (a: T, b: T) => boolean,
+  results: FieldOutcome[],
+): Promise<void> {
+  for (const [key, spec] of Object.entries(table)) {
+    if (!(key in payload)) continue;
+
+    const coerced = coerce(payload[key]);
+    if ('error' in coerced) {
+      results.push({ key, outcome: 'error', reason: coerced.error });
+      continue;
+    }
+
+    try {
+      const current = await spec.get();
+      if (equals(current, coerced.value)) {
+        results.push({ key, outcome: 'skipped', value: coerced.value });
+        continue;
+      }
+      await spec.set(coerced.value);
+      results.push({ key, outcome: 'applied', value: coerced.value });
+    } catch (e) {
+      results.push({ key, outcome: 'error', reason: e instanceof Error ? e.message : String(e) });
+    }
+  }
+}
+
+const scalarEquals = <T,>(a: T, b: T) => a === b;
+const arrayEquals = (a: any[], b: any[]) => JSON.stringify(a) === JSON.stringify(b);
+
+/**
+ * Apply the flattened restrictions bundle's fields. Assumes the caller has
+ * already decided config_version changed.
+ */
+async function applyBulk(payload: Record<string, unknown>): Promise<BulkApplyResult> {
+  const results: FieldOutcome[] = [];
+
+  await applyFieldGroup<boolean>(payload, BOOL_FIELDS, (v) => ({ value: toBool(v) }), scalarEquals, results);
+  await applyFieldGroup<string>(payload, STRING_FIELDS, (v) => ({ value: toStr(v) }), scalarEquals, results);
+  await applyFieldGroup<number>(
+    payload,
+    NUMBER_FIELDS,
+    (v) => {
+      const n = toNum(v);
+      return n !== undefined ? { value: n } : { error: `"${String(v)}" is not a finite number` };
+    },
+    scalarEquals,
+    results,
+  );
+  await applyFieldGroup<any[]>(
+    payload,
+    ARRAY_FIELDS,
+    (v) => {
+      const list = resolveList(v);
+      return list !== undefined ? { value: list } : { error: 'value is not an array (and not the ["__CLEAR__"] sentinel)' };
+    },
+    arrayEquals,
+    results,
+  );
+
+  return {
+    applied: results
+      .filter((r): r is { key: string; outcome: 'applied'; value: unknown } => r.outcome === 'applied')
+      .map((r) => ({ key: r.key, value: r.value })),
+    skipped: results
+      .filter((r): r is { key: string; outcome: 'skipped'; value: unknown } => r.outcome === 'skipped')
+      .map((r) => ({ key: r.key, value: r.value })),
+    errors: results
+      .filter((r): r is { key: string; outcome: 'error'; reason: string } => r.outcome === 'error')
+      .map((r) => ({ key: r.key, reason: r.reason })),
+  };
+}
+
+export interface ApplyResult {
+  /** PIN was changed (never triggers a reload). */
+  pinChanged: boolean;
+  /** At least one bulk field was actually written (triggers a live reload). */
+  bulkApplied: boolean;
+}
+
+/**
+ * Top-level entry: apply an incoming restrictions bundle.
+ *
+ * `restrictions` is the whole App Restrictions object as read by the native
+ * module. Per convention 5, the launcher flattens the managedConfig
+ * attribute's JSON keys directly into the top level of this bundle — there is
+ * no nested `managedConfig` object on the device. So `config_version`, every
+ * setting key, and the PIN siblings (`kiosk_pin`, `kiosk_pin_label`) all live
+ * directly on `restrictions`.
+ */
+export async function applyManagedConfig(
+  restrictions: Record<string, unknown> | null | undefined,
+  native: ManagedConfigNative | undefined,
+): Promise<ApplyResult> {
+  const result: ApplyResult = { pinChanged: false, bulkApplied: false };
+  if (!restrictions) {
+    console.log('[ManagedConfig] no restrictions bundle; nothing to apply');
+    return result;
+  }
+  console.log('[ManagedConfig] restrictions received, keys=', Object.keys(restrictions));
+
+  // 1. PIN — ungated, every emission (top-level kiosk_pin).
+  try {
+    result.pinChanged = await applyPin(restrictions, native);
+  } catch (e) {
+    console.warn('[ManagedConfig] applyPin failed:', e);
+  }
+
+  // 2 + 3. Bulk config, gated on config_version — read from the TOP LEVEL of
+  // the (flattened) restrictions bundle, not a nested object.
+  const incomingVersion =
+    restrictions.config_version !== undefined && restrictions.config_version !== null
+      ? String(restrictions.config_version)
+      : undefined;
+
+  if (incomingVersion === undefined) {
+    console.log('[ManagedConfig] no config_version present; skipping bulk apply (PIN-only or empty push)');
+    return result;
+  }
+
+  const lastVersion = await StorageService.getManagedConfigVersion();
+  console.log(`[ManagedConfig] config_version incoming=${incomingVersion} last=${lastVersion ?? '(none)'}`);
+
+  const fingerprint = computeFingerprint(restrictions);
+
+  // Convention 7a: same version — routine re-delivery vs unbumped edit.
+  if (incomingVersion === lastVersion) {
+    const lastFingerprint = await StorageService.getManagedConfigFingerprint();
+    if (lastFingerprint !== null && lastFingerprint !== fingerprint) {
+      logError(
+        native,
+        `config #${incomingVersion} rejected — payload content changed but config_version was not bumped (still ${incomingVersion}). Increment config_version for these changes to apply.`,
+      );
+      await reportConfigAck(native, incomingVersion, 'Error');
+    } else {
+      console.log('[ManagedConfig] config_version unchanged; skipping bulk apply (routine re-delivery)');
+    }
+    return result;
+  }
+
+  // Convention 7b: numeric version regression.
+  const incomingNum = Number(incomingVersion);
+  const lastNum = lastVersion !== null ? Number(lastVersion) : NaN;
+  if (Number.isFinite(incomingNum) && Number.isFinite(lastNum) && incomingNum < lastNum) {
+    logError(
+      native,
+      `config #${incomingVersion} rejected — version regression (incoming ${incomingVersion} is lower than last applied ${lastVersion}). Use a config_version higher than ${lastVersion}.`,
+    );
+    await reportConfigAck(native, incomingVersion, 'Error');
+    return result;
+  }
+
+  // Convention 8: push-shape validation — unknown keys and the optional
+  // config_fields manifest. Non-blocking: valid fields still apply below.
+  const shapeErrors: string[] = [];
+  const unknownKeys = Object.keys(restrictions).filter(
+    (k) => !KNOWN_FIELD_KEYS.has(k) && !RESERVED_KEYS.has(k),
+  );
+  if (unknownKeys.length > 0) {
+    shapeErrors.push(
+      `unrecognized field(s) [${unknownKeys.join(', ')}] — check spelling and case (keys are case-sensitive)`,
+    );
+  }
+  const announced = parseConfigFields(restrictions.config_fields);
+  if (announced) {
+    const announcedUnknown = announced.filter((k) => !KNOWN_FIELD_KEYS.has(k));
+    if (announcedUnknown.length > 0) {
+      shapeErrors.push(`config_fields announces unknown field name(s) [${announcedUnknown.join(', ')}]`);
+    }
+    const missingAnnounced = announced.filter((k) => KNOWN_FIELD_KEYS.has(k) && !(k in restrictions));
+    if (missingAnnounced.length > 0) {
+      shapeErrors.push(
+        `field(s) announced in config_fields but missing from the delivered payload [${missingAnnounced.join(', ')}] — likely dropped upstream by the launcher parser (unquoted decimal, or a number beyond 32-bit range?)`,
+      );
+    }
+  }
+  for (const msg of shapeErrors) {
+    logError(native, `config #${incomingVersion} — ${msg}`);
+  }
+
+  const bulkResult = await applyBulk(restrictions);
+  await StorageService.saveManagedConfigVersion(incomingVersion);
+  await StorageService.saveManagedConfigFingerprint(fingerprint);
+  result.bulkApplied = bulkResult.applied.length > 0;
+
+  const status: 'Success' | 'Error' =
+    bulkResult.errors.length === 0 && shapeErrors.length === 0 ? 'Success' : 'Error';
+
+  // Three independent business-outcome logs, each only emitted when there's
+  // something to say, each carrying the actual field value (not just the key
+  // name) so the log line is self-sufficient without cross-referencing the
+  // push that caused it.
+  if (bulkResult.applied.length > 0) {
+    const appliedStr = bulkResult.applied.map((f) => `${f.key} = ${formatValue(f.value)}`).join(', ');
+    logInfo(native, `config #${incomingVersion} applied successfully. Applied [${appliedStr}]`);
+  }
+  if (bulkResult.skipped.length > 0) {
+    const skippedStr = bulkResult.skipped.map((f) => `${f.key} = ${formatValue(f.value)}`).join(', ');
+    logWarn(native, `config #${incomingVersion} — already matched device [${skippedStr}]`);
+  }
+  if (bulkResult.errors.length > 0) {
+    const errorStr = bulkResult.errors.map((e) => `${e.key} (${e.reason})`).join('; ');
+    logError(native, `config #${incomingVersion} had ${bulkResult.errors.length} field failure(s): ${errorStr}`);
+  }
+  if (bulkResult.applied.length === 0 && bulkResult.skipped.length === 0 && bulkResult.errors.length === 0) {
+    logInfo(native, `config #${incomingVersion} — no known fields present in payload`);
+  }
+
+  // Ack on every version advance (even a fully-skipped, no-op push), so the
+  // console's custom1 column reliably reflects "device saw version N" and
+  // whether it fully succeeded.
+  await reportConfigAck(native, incomingVersion, status);
+
+  return result;
+}
