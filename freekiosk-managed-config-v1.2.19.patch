+/**
+ * Side-effect-free check of whether a candidate PIN equals the currently
+ * stored one — re-hashes the candidate with the stored salt and compares.
+ *
+ * Unlike verifySecurePin(), this records NO failed attempt and never triggers
+ * lockout, because it is not an authentication path: it exists only so the
+ * managed-config apply loop can decide whether an incoming remote PIN push is
+ * a real change (and skip re-saving / re-acking if it isn't). Never wire this
+ * into a user-facing unlock flow.
+ *
+ * Returns false when there is no stored PBKDF2 PIN (e.g. only a legacy
+ * plaintext PIN, or none) so the caller treats the push as a change and lets
+ * saveSecurePin() establish the secure record.
+ */
+export async function securePinMatches(candidatePin: string): Promise<boolean> {
+  try {
+    const credentials = await Keychain.getGenericPassword({ service: PIN_SERVICE });
+    if (!credentials) {
+      return false;
+    }
+    const { hash, salt } = JSON.parse(credentials.password);
+    if (typeof hash !== 'string' || typeof salt !== 'string') {
+      return false;
+    }
+    const candidateHash = await hashPin(candidatePin, hexToBytes(salt));
+    return candidateHash === hash;
+  } catch (error) {
+    console.error('[SecureStorage] Error comparing PIN:', error);
+    return false;
+  }
+}
+
 /**
  * Migrate old plaintext PIN to secure storage
  */
