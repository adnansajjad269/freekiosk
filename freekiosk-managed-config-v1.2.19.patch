index 0000000..cf3fe29
--- /dev/null
+++ b/src/hooks/useManagedConfigSync.ts
@@ -0,0 +1,70 @@
+import { useEffect } from 'react';
+import { NativeModules, NativeEventEmitter } from 'react-native';
+import { applyManagedConfig, ApplyResult, ManagedConfigNative } from '../utils/applyManagedConfig';
+import { kioskScreenActionsRef } from '../utils/kioskScreenActions';
+
+const { ManagedConfig } = NativeModules as {
+  ManagedConfig?: ManagedConfigNative & {
+    getConfig(): Promise<Record<string, unknown>>;
+  };
+};
+
+/**
+ * App-root effect: applies Headwind MDM managed configuration (App
+ * Restrictions) whenever it changes, and refreshes the currently-mounted
+ * Kiosk screen live so a mid-session change is visible without a manual
+ * background/foreground or a reboot — no different from how PIN changes
+ * already take effect.
+ *
+ * Reload trigger: calls kioskScreenActionsRef.current?.reloadSettings()
+ * directly (see src/utils/kioskScreenActions.ts) whenever the bulk config
+ * actually wrote at least one field — never for a PIN-only change (the PIN is
+ * read fresh at PIN-entry time; nothing on screen is stale), and never for a
+ * push where every field already matched the device (nothing to refresh).
+ * This is not a navigation action, so it never interrupts a supervisor
+ * mid-edit in Settings/PinScreen — it just quietly updates KioskScreen's
+ * state, which is visible instantly if Kiosk is in the foreground and
+ * otherwise already correct the next time the user navigates back to it.
+ */
+export function useManagedConfigSync(): void {
+  useEffect(() => {
+    if (!ManagedConfig) {
+      // Native module not present (e.g. non-managed build/device) — no-op.
+      return;
+    }
+
+    let mounted = true;
+    const emitter = new NativeEventEmitter(ManagedConfig as any);
+
+    const handleReload = (result: ApplyResult) => {
+      if (!result.bulkApplied) return;
+      kioskScreenActionsRef.current?.reloadSettings();
+    };
+
+    const apply = async (restrictions: Record<string, unknown>) => {
+      try {
+        const result = await applyManagedConfig(restrictions, ManagedConfig);
+        if (mounted) handleReload(result);
+      } catch (e) {
+        console.warn('[ManagedConfig] apply failed:', e);
+      }
+    };
+
+    ManagedConfig.getConfig()
+      .then((cfg) => {
+        if (mounted) apply(cfg);
+      })
+      .catch(() => {
+        /* no config yet — ignore */
+      });
+
+    const sub = emitter.addListener('managedConfigChanged', (cfg) => {
+      if (mounted) apply(cfg as Record<string, unknown>);
+    });
+
+    return () => {
+      mounted = false;
+      sub.remove();
+    };
+  }, []);
+}
