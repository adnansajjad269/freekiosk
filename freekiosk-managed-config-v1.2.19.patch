index 0000000..270314c
--- /dev/null
+++ b/src/utils/applyManagedConfig.ts
@@ -0,0 +1,636 @@
+/**
+ * applyManagedConfig — applies a Headwind MDM managed-configuration payload
+ * (Android App Restrictions) onto FreeKiosk's local settings.
+ *
+ * Delivery: the Headwind launcher (device owner) pushes an "Application setting"
+ * for com.freekiosk. The `managedConfig` attribute carries a JSON blob of all
+ * fleet-wide settings plus a `config_version`; `kiosk_pin` / `kiosk_pin_label`
+ * arrive as top-level sibling attributes (per-device PIN rotation). The native
+ * ManagedConfigModule reads the whole restrictions bundle and hands it here.
+ *
+ * Conventions this file depends on (see the managed-config plan):
+ *   1. Any number that can exceed 32-bit int range — AND ANY DECIMAL — must be
+ *      sent as a JSON *string*. The launcher's parseManagedConfig has TWO cast
+ *      bugs: Long→(int) and Double→(float), both throwing ClassCastException
+ *      mid-parse; every key AFTER the offending one is silently dropped
+ *      (earlier keys survive, which is why config_version — always first —
+ *      keeps arriving while later fields vanish). Number fields here coerce
+ *      with Number(), which accepts numeric strings, so quoting is lossless.
+ *   2. A list cannot be emptied with a bare [] (the launcher skips zero-length
+ *      arrays). The sentinel ["__CLEAR__"] means "set this list to empty".
+ *   3. kiosk_pin is a top-level, ungated, normalized, separately-acked entry —
+ *      applied on every emission regardless of config_version (per-device PIN
+ *      pushes don't bump the fleet version). See applyPin().
+ *   4. Object-array fields arrive as arrays of plain objects (native converts
+ *      the launcher's Parcelable[] of Bundles); they are passed straight to the
+ *      setters, which persist them as JSON.
+ *   5. The launcher FLATTENS the managedConfig attribute's JSON keys directly
+ *      into the top level of the restrictions bundle — there is no nested
+ *      `managedConfig` object on the device (see AppRestrictionUpdater on the
+ *      launcher side). `config_version` and every field key are read from the
+ *      top level of `restrictions`.
+ *   6. Every field is compared against its CURRENT on-device value (via the
+ *      matching StorageService getter) before writing. A value identical to
+ *      what's already stored is left alone ("skipped"), not rewritten — a
+ *      push is a list of desired values, not a list of commands, so one
+ *      field matching what's already there never blocks any other field in
+ *      the same push. See applyBulk()/applyFieldGroup().
+ *   7. Version gating with content fingerprint: same version + same payload =
+ *      routine re-delivery (silent skip; the launcher re-sends on every sync
+ *      and app restart). Same version + CHANGED payload = operator forgot to
+ *      bump config_version → ERROR, nothing applied. Numerically LOWER
+ *      version than last applied = regression → ERROR, nothing applied.
+ *   8. Push-shape validation: unknown keys (typos/case mistakes) are reported
+ *      as errors; the optional `config_fields` key (comma-separated string of
+ *      expected field names) lets the device detect fields that were dropped
+ *      upstream by the launcher parser bugs and report them as errors too.
+ *      Both are non-blocking — valid fields in the same push still apply.
+ */
+
+import { StorageService } from './storage';
+import { saveSecurePin, securePinMatches } from './secureStorage';
+
+// Must match the fleet's actual configured PIN length so an admin who forgets
+// to quote the value in the console (pushing it as an integer) still gets the
+// correct zero-padded string on-device. Correct quoting remains the primary
+// rule; this padding is only a safety net.
+export const KIOSK_PIN_LENGTH = 6;
+
+const CLEAR_SENTINEL = '__CLEAR__';
+
+// Native module surface used for the acknowledgement side-channel and
+// optional remote-log forwarding (see logRemote below).
+export interface ManagedConfigNative {
+  reportCustom(slot: number, value: string): Promise<boolean>;
+  /**
+   * Fire-and-forget: forwards a log line to the Headwind launcher's remote-log
+   * pipeline (MDMService.Log on the native side), which ALSO logs locally.
+   * Whether it reaches the webconsole's Device Log tab depends on a
+   * server-side log rule matching com.freekiosk; without one this is a
+   * harmless no-op beyond the native-side local log.
+   */
+  logRemote?(level: 'INFO' | 'WARNING' | 'ERROR', message: string): void;
+}
+
+// ---- coercion helpers ------------------------------------------------------
+
+function toBool(v: unknown): boolean {
+  if (typeof v === 'boolean') return v;
+  if (typeof v === 'number') return v !== 0;
+  if (typeof v === 'string') return v === 'true' || v === '1';
+  return false;
+}
+
+function toNum(v: unknown): number | undefined {
+  // Convention 1: numeric strings are first-class here.
+  const n = typeof v === 'number' ? v : Number(v);
+  return Number.isFinite(n) ? n : undefined;
+}
+
+function toStr(v: unknown): string {
+  return v == null ? '' : String(v);
+}
+
+/** Convention 2: resolve the ["__CLEAR__"] sentinel to a real empty array. */
+function resolveList<T>(v: unknown): T[] | undefined {
+  if (!Array.isArray(v)) return undefined;
+  if (v.length === 1 && v[0] === CLEAR_SENTINEL) return [];
+  return v as T[];
+}
+
+/** Render a field value for a log line — compact, human-readable. */
+function formatValue(v: unknown): string {
+  if (typeof v === 'string' || typeof v === 'number' || typeof v === 'boolean') return String(v);
+  try {
+    return JSON.stringify(v);
+  } catch {
+    return String(v);
+  }
+}
+
+/**
+ * Log a business-outcome message both locally (console) and — if the native
+ * module supports it — via logRemote(), so it can be forwarded to the
+ * Headwind launcher's remote-log pipeline and, if a server-side log rule
+ * matches, show up in the webconsole's Device Log tab.
+ */
+function logInfo(native: ManagedConfigNative | undefined, message: string) {
+  console.log(`[ManagedConfig] INFO: ${message}`);
+  try {
+    native?.logRemote?.('INFO', message);
+  } catch (e) {
+    console.warn('[ManagedConfig] logRemote(INFO) failed:', e);
+  }
+}
+
+function logWarn(native: ManagedConfigNative | undefined, message: string) {
+  console.warn(`[ManagedConfig] WARNING: ${message}`);
+  try {
+    native?.logRemote?.('WARNING', message);
+  } catch (e) {
+    console.warn('[ManagedConfig] logRemote(WARNING) failed:', e);
+  }
+}
+
+function logError(native: ManagedConfigNative | undefined, message: string) {
+  console.error(`[ManagedConfig] ERROR: ${message}`);
+  try {
+    native?.logRemote?.('ERROR', message);
+  } catch (e) {
+    console.warn('[ManagedConfig] logRemote(ERROR) failed:', e);
+  }
+}
+
+// ---- apply table -----------------------------------------------------------
+//
+// Grouped by value type to stay mechanical. Each entry pairs a managedConfig
+// JSON key with the StorageService getter/setter that reads and writes it —
+// the getter is what makes per-field "is this actually different" diffing
+// possible (convention 6). Enum-valued fields live in the string group; the
+// setters themselves validate/narrow.
+//
+// Deliberately excluded (per plan): rest_api_key, mqtt_password,
+// http_basic_auth_password (secrets stay GUI-only), and kiosk_pin (handled by
+// applyPin, out-of-band from config_version gating).
+
+interface FieldSpec<T> {
+  get: () => Promise<T>;
+  set: (value: T) => Promise<void>;
+}
