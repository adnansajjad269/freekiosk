+  webview_back_button_x_percent: { get: StorageService.getWebViewBackButtonXPercent, set: StorageService.saveWebViewBackButtonXPercent },
+  webview_back_button_y_percent: { get: StorageService.getWebViewBackButtonYPercent, set: StorageService.saveWebViewBackButtonYPercent },
+  auto_brightness_min: { get: StorageService.getAutoBrightnessMin, set: StorageService.saveAutoBrightnessMin },
