new file mode 100644
index 0000000..8b9db94
--- /dev/null
+++ b/src/hooks/useManagedConfigSync.ts
@@ -0,0 +1,72 @@
+import { useEffect } from 'react';
+import { NativeModules, NativeEventEmitter } from 'react-native';
+import { applyManagedConfig, ApplyResult, ManagedConfigNative } from '../utils/applyManagedConfig';
+import { navigationRef } from '../navigation/AppNavigator';
+
+const { ManagedConfig } = NativeModules as {
+  ManagedConfig?: ManagedConfigNative & {
+    getConfig(): Promise<Record<string, unknown>>;
+  };
+};
+
+/**
+ * App-root effect: applies Headwind MDM managed configuration (App
+ * Restrictions) whenever it changes, and — only when safe — reloads the Kiosk
+ * screen so a mid-session change is visible without a manual background/
+ * foreground.
+ *
+ * Reload guard (plan convention): a reload is a navigation.reset() to Kiosk,
+ * which remounts KioskScreen/the WebView (a visible flash). It fires ONLY when:
+ *   (a) the bulk config actually changed (never for a PIN-only change — the PIN
+ *       is read fresh at PIN-entry time, nothing on screen is stale), AND
+ *   (b) the current route is already Kiosk — otherwise a supervisor mid-edit in
+ *       Settings/PinScreen would be ejected and lose unsaved work. Off Kiosk,
+ *       the persisted values are picked up naturally by loadSettings() on the
+ *       next focus.
+ */
+export function useManagedConfigSync(): void {
+  useEffect(() => {
+    if (!ManagedConfig) {
+      // Native module not present (e.g. non-managed build/device) — no-op.
+      return;
+    }
+
+    let mounted = true;
+    const emitter = new NativeEventEmitter(ManagedConfig as any);
+
+    const handleReload = (result: ApplyResult) => {
+      if (!result.bulkApplied) return;
+      if (!navigationRef.isReady()) return;
+      const current = navigationRef.getCurrentRoute()?.name;
+      if (current === 'Kiosk') {
+        navigationRef.reset({ index: 0, routes: [{ name: 'Kiosk' }] });
+      }
+    };
+
+    const apply = async (restrictions: Record<string, unknown>) => {
+      try {
+        const result = await applyManagedConfig(restrictions, ManagedConfig);
+        if (mounted) handleReload(result);
+      } catch (e) {
+        console.warn('[ManagedConfig] apply failed:', e);
+      }
+    };
+
+    ManagedConfig.getConfig()
+      .then((cfg) => {
+        if (mounted) apply(cfg);
+      })
+      .catch(() => {
+        /* no config yet — ignore */
+      });
+
+    const sub = emitter.addListener('managedConfigChanged', (cfg) => {
+      if (mounted) apply(cfg as Record<string, unknown>);
+    });
+
+    return () => {
+      mounted = false;
+      sub.remove();
+    };
+  }, []);
+}
