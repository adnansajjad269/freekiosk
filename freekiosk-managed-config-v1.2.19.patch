@@ -0,0 +1,24 @@
+/**
+ * Live-reload registration for KioskScreen.
+ *
+ * Lets the managed-config applier refresh currently-loaded settings on the
+ * mounted Kiosk screen directly — no navigation, no remount, no reboot —
+ * exactly matching how PIN changes already take effect (read fresh at
+ * PIN-entry time, nothing to refresh). React Navigation's native-stack keeps
+ * KioskScreen mounted in the background when Settings/Pin are pushed on top
+ * (no `unmountOnBlur`), so calling reloadSettings() here is always safe: if
+ * Kiosk is the foreground screen the update is visible instantly; if not, the
+ * background screen is quietly refreshed and shows the new state the moment
+ * the user navigates back — either way nothing is ever interrupted mid-edit.
+ *
+ * KioskScreen registers itself on mount / clears on unmount; a plain module
+ * ref (not a React ref) is used because the applier lives outside the
+ * component tree (called from a native-event listener at the app root).
+ */
+export interface KioskScreenActions {
+  reloadSettings: () => void;
+}
+
+export const kioskScreenActionsRef: { current: KioskScreenActions | null } = {
+  current: null,
+};
