diff --git a/android/app/src/main/java/com/freekiosk/ManagedConfigModule.kt b/android/app/src/main/java/com/freekiosk/ManagedConfigModule.kt
new file mode 100644
index 0000000..1c9d2e2
--- /dev/null
+++ b/android/app/src/main/java/com/freekiosk/ManagedConfigModule.kt
@@ -0,0 +1,305 @@
+package com.freekiosk
+
+import android.content.BroadcastReceiver
+import android.content.Context
+import android.content.Intent
+import android.content.IntentFilter
+import android.os.Bundle
+import android.os.Handler
+import android.os.Looper
+import android.os.Parcelable
+import android.os.UserManager
+import android.util.Log
+import com.facebook.react.bridge.Arguments
+import com.facebook.react.bridge.Promise
+import com.facebook.react.bridge.ReactApplicationContext
+import com.facebook.react.bridge.ReactContextBaseJavaModule
+import com.facebook.react.bridge.ReactMethod
+import com.facebook.react.bridge.WritableArray
+import com.facebook.react.bridge.WritableMap
+import com.facebook.react.modules.core.DeviceEventManagerModule
+import com.hmdm.HeadwindMDM
+import com.hmdm.MDMService
+
+/**
+ * Bridges Android Managed Configurations (App Restrictions) — pushed by the
+ * Headwind MDM launcher (device owner) via setApplicationRestrictions() — into
+ * FreeKiosk's JS layer, and reports an applied-config acknowledgement back to
+ * the launcher via the vendored com.hmdm client lib (setCustom → device custom
+ * fields → server sync).
+ *
+ * JS API:
+ *   ManagedConfig.getConfig(): Promise<object>       current restrictions bundle
+ *   ManagedConfig.reportCustom(slot, value): Promise  ack via HeadwindMDM.setCustom
+ *   ManagedConfig.logRemote(level, message)           fire-and-forget; forwards to the
+ *                                                      launcher's remote-log pipeline via
+ *                                                      MDMService.Log (also logs locally).
+ *                                                      Only reaches the webconsole's Device
+ *                                                      Log tab if a server-side log rule
+ *                                                      matches com.freekiosk — otherwise a
+ *                                                      harmless local-only no-op.
+ *   event "managedConfigChanged": object              fired on every restrictions change
+ *
+ * See CLAUDE.md / the managed-config plan for the four schema conventions this
+ * relies on (large-numbers-as-strings, the ["__CLEAR__"] empty-list sentinel,
+ * the ungated top-level kiosk_pin entry, and Parcelable[] round-trip fidelity).
+ */
+class ManagedConfigModule(reactContext: ReactApplicationContext) :
+    ReactContextBaseJavaModule(reactContext) {
+
+    companion object {
+        private const val TAG = "ManagedConfig"
+        private const val EVENT_NAME = "managedConfigChanged"
+
+        // Mirror the vendored lib's own reconnect cadence (Const is package-private
+        // in com.hmdm so its constants aren't visible here — keep these in sync).
+        private const val CONNECT_RETRY_DELAY_FIRST_MS = 5000L
+        private const val CONNECT_RETRY_DELAY_NEXT_MS = 60000L
+    }
+
+    private val mainHandler = Handler(Looper.getMainLooper())
+
+    // HeadwindMDM connection state. `mdmConnected` flips true only after the lib
+    // reports a successful bind to the launcher's PluginApiService.
+    @Volatile private var mdmConnected = false
+    private var connectStarted = false
+
+    // reportCustom() calls issued before the bind completes are coalesced here
+    // (latest value per slot wins) and flushed once connected — the launcher
+    // only keeps the last value per custom slot anyway, so coalescing is lossless.
+    private val pendingCustom = HashMap<Int, String>()
+
+    private val restrictionsReceiver = object : BroadcastReceiver() {
+        override fun onReceive(context: Context?, intent: Intent?) {
+            emitConfig()
+        }
+    }
+    private var receiverRegistered = false
+
+    private val mdmEventHandler = object : HeadwindMDM.EventHandler {
+        override fun onHeadwindMDMConnected() {
+            mdmConnected = true
+            Log.i(TAG, "HeadwindMDM connected; flushing ${pendingCustom.size} pending custom field(s)")
+            flushPendingCustom()
+        }
+
+        override fun onHeadwindMDMDisconnected() {
+            mdmConnected = false
+        }
+
+        override fun onHeadwindMDMConfigChanged() {
+            // The launcher signals a config update; re-read restrictions and notify JS.
+            // (Redundant with ACTION_APPLICATION_RESTRICTIONS_CHANGED, but this fires
+            // reliably even on transports where the system broadcast is delayed.)
+            emitConfig()
+        }
+    }
+
+    override fun getName(): String = "ManagedConfig"
+
+    override fun initialize() {
+        super.initialize()
+        registerReceiver()
+        startMdmConnect()
+    }
+
+    override fun invalidate() {
+        if (receiverRegistered) {
+            try {
+                reactApplicationContext.unregisterReceiver(restrictionsReceiver)
+            } catch (ignored: IllegalArgumentException) {
+            }
+            receiverRegistered = false
+        }
+        mainHandler.removeCallbacksAndMessages(null)
+        super.invalidate()
+    }
+
+    private fun registerReceiver() {
+        if (receiverRegistered) return
+        // ACTION_APPLICATION_RESTRICTIONS_CHANGED is delivered ONLY to runtime-
+        // registered receivers, never manifest-declared ones. FreeKiosk is a
+        // permanent foreground lock-task app, so registering here is sufficient.
+        val filter = IntentFilter(Intent.ACTION_APPLICATION_RESTRICTIONS_CHANGED)
+        reactApplicationContext.registerReceiver(restrictionsReceiver, filter)
+        receiverRegistered = true
+    }
+
+    /**
+     * Own retry-with-backoff loop around the FIRST connect(). The lib's internal
+     * MDMReconnectRunnable only kicks in after a previously-successful connection
+     * later drops — it does NOT retry an initial bind that failed because the
+     * launcher service wasn't up yet (the cold-boot race). So we drive the first
+     * successful bind ourselves.
+     */
+    private fun startMdmConnect() {
+        if (connectStarted) return
+        connectStarted = true
+        attemptConnect(CONNECT_RETRY_DELAY_FIRST_MS)
+    }
+
+    private fun attemptConnect(nextDelayMs: Long) {
+        if (mdmConnected) return
+        val available = try {
+            // connect() returns false if Headwind MDM isn't present/bindable yet.
+            HeadwindMDM.getInstance().connect(reactApplicationContext, mdmEventHandler)
+        } catch (e: Exception) {
+            Log.w(TAG, "HeadwindMDM.connect() threw: ${e.message}")
+            false
+        }
+        if (!available && !mdmConnected) {
+            mainHandler.postDelayed(
+                { attemptConnect(CONNECT_RETRY_DELAY_NEXT_MS) },
+                nextDelayMs,
+            )
+        }
+    }
+
+    private fun flushPendingCustom() {
+        if (!mdmConnected || pendingCustom.isEmpty()) return
+        val snapshot = HashMap(pendingCustom)
+        for ((slot, value) in snapshot) {
+            if (HeadwindMDM.getInstance().setCustom(slot, value)) {
+                pendingCustom.remove(slot)
+            }
+        }
+    }
+
+    @ReactMethod
+    fun getConfig(promise: Promise) {
+        try {
+            promise.resolve(readRestrictions())
+        } catch (e: Exception) {
+            promise.reject("MANAGED_CONFIG_ERROR", e)
+        }
+    }
+
+    /**
+     * Report a value to a Headwind device custom field (1..3) as an
+     * acknowledgement. If the lib isn't bound yet, the value is queued and
+     * flushed on connect rather than silently no-op'ing.
+     */
+    @ReactMethod
+    fun reportCustom(slot: Int, value: String, promise: Promise) {
+        try {
+            if (mdmConnected && HeadwindMDM.getInstance().setCustom(slot, value)) {
+                promise.resolve(true)
+            } else {
+                // Not connected (or setCustom returned false because the bind
+                // dropped) — queue it; flushPendingCustom() retries on connect.
+                pendingCustom[slot] = value
+                startMdmConnect()
+                promise.resolve(false)
+            }
+        } catch (e: Exception) {
+            promise.reject("MANAGED_CONFIG_REPORT_ERROR", e)
+        }
+    }
+
+    /**
+     * Forward a log line to the Headwind launcher's remote-log pipeline
+     * (MDMService.Log — also logs locally under logcat tag [TAG]). Fire and
+     * forget: no promise, since a logging call should never block or fail
+     * JS-side just because the MDM bind isn't up yet. Whether this actually
+     * reaches the webconsole's Device Log tab depends entirely on a
+     * server-side log rule matching com.freekiosk (LogConfigTable.match on
+     * the launcher side) — without one it's a no-op beyond the local log.
+     */
+    @ReactMethod
+    fun logRemote(level: String, message: String) {
+        try {
+            when (level.uppercase()) {
+                "ERROR" -> MDMService.Log.e(TAG, message)
+                "WARNING", "WARN" -> MDMService.Log.w(TAG, message)
+                "INFO" -> MDMService.Log.i(TAG, message)
+                "DEBUG" -> MDMService.Log.d(TAG, message)
+                "VERBOSE" -> MDMService.Log.v(TAG, message)
+                else -> MDMService.Log.i(TAG, message)
+            }
+        } catch (e: Exception) {
+            Log.w(TAG, "logRemote failed: ${e.message}")
+        }
+    }
+
+    // Required no-op stubs so NativeEventEmitter doesn't warn on RN >= 0.65.
+    @ReactMethod
+    fun addListener(eventName: String) {
+    }
+
+    @ReactMethod
+    fun removeListeners(count: Int) {
+    }
+
+    private fun emitConfig() {
+        val ctx = reactApplicationContext
+        if (!ctx.hasActiveReactInstance()) return
+        ctx.getJSModule(DeviceEventManagerModule.RCTDeviceEventEmitter::class.java)
+            .emit(EVENT_NAME, readRestrictions())
+    }
+
+    private fun readRestrictions(): WritableMap {
+        val um = reactApplicationContext.getSystemService(Context.USER_SERVICE) as? UserManager
+        val restrictions = um?.getApplicationRestrictions(reactApplicationContext.packageName)
+        return bundleToMap(restrictions ?: Bundle())
+    }
+
+    /**
+     * Bundle → WritableMap, handling every value type parseManagedConfig() on the
+     * launcher side can produce. The Parcelable[] branch (object arrays: managed
+     * apps, dashboard tiles, planner events, schedule rules, blocking regions,
+     * media playlist) is the non-obvious one and the single largest correctness
+     * surface — ported from the abandoned managed-config-sync branch's Java module.
+     */
+    private fun bundleToMap(bundle: Bundle): WritableMap {
+        val map = Arguments.createMap()
+        for (key in bundle.keySet()) {
+            when (val value = bundle.get(key)) {
+                null -> map.putNull(key)
+                is Boolean -> map.putBoolean(key, value)
+                is Int -> map.putInt(key, value)
+                is Long -> map.putDouble(key, value.toDouble())
+                is Float -> map.putDouble(key, value.toDouble())
+                is Double -> map.putDouble(key, value)
+                is String -> map.putString(key, value)
+                is Bundle -> map.putMap(key, bundleToMap(value))
+                is Array<*> -> map.putArray(key, arrayToWritable(value))
+                is IntArray -> {
+                    val arr = Arguments.createArray()
+                    for (n in value) arr.pushInt(n)
+                    map.putArray(key, arr)
+                }
+                is BooleanArray -> {
+                    val arr = Arguments.createArray()
+                    for (b in value) arr.pushBoolean(b)
+                    map.putArray(key, arr)
+                }
+                else -> map.putString(key, value.toString())
+            }
+        }
+        return map
+    }
+
+    private fun arrayToWritable(array: Array<*>): WritableArray {
+        val arr = Arguments.createArray()
+        for (element in array) {
+            when (element) {
+                null -> arr.pushNull()
+                is Bundle -> arr.pushMap(bundleToMap(element))
+                is Parcelable -> {
+                    // parseManagedConfig() emits nested objects as Bundle Parcelables;
+                    // anything non-Bundle we can't meaningfully represent, so skip it
+                    // rather than crash.
+                    if (element is Bundle) arr.pushMap(bundleToMap(element))
+                }
+                is String -> arr.pushString(element)
+                is Boolean -> arr.pushBoolean(element)
+                is Int -> arr.pushInt(element)
+                is Long -> arr.pushDouble(element.toDouble())
+                is Float -> arr.pushDouble(element.toDouble())
+                is Double -> arr.pushDouble(element)
+                else -> arr.pushString(element.toString())
+            }
+        }
+        return arr
+    }
+}
