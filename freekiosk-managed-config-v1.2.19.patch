index 0000000..bb4fac4
--- /dev/null
+++ b/src/utils/applyManagedConfig.ts
@@ -0,0 +1,379 @@
+/**
+ * applyManagedConfig — applies a Headwind MDM managed-configuration payload
+ * (Android App Restrictions) onto FreeKiosk's local settings.
+ *
+ * Delivery: the Headwind launcher (device owner) pushes an "Application setting"
+ * for com.freekiosk. The `managedConfig` attribute carries a JSON blob of all
+ * fleet-wide settings plus a `config_version`; `kiosk_pin` / `kiosk_pin_label`
+ * arrive as top-level sibling attributes (per-device PIN rotation). The native
+ * ManagedConfigModule reads the whole restrictions bundle and hands it here.
+ *
+ * Four schema conventions this file depends on (see the managed-config plan):
+ *   1. Any number that can exceed 32-bit int range is sent as a JSON *string*
+ *      (the launcher's parseManagedConfig has a Long→int cast bug that would
+ *      otherwise silently drop the entire blob). Number fields here coerce with
+ *      Number(), which accepts both real numbers and numeric strings, so this is
+ *      handled uniformly.
+ *   2. A list cannot be emptied with a bare [] (the launcher skips zero-length
+ *      arrays). The sentinel ["__CLEAR__"] means "set this list to empty".
+ *   3. kiosk_pin is a top-level, ungated, normalized, separately-acked entry —
+ *      applied on every emission regardless of config_version (per-device PIN
+ *      pushes don't bump the fleet version). See applyPin().
+ *   4. Object-array fields arrive as arrays of plain objects (native converts
+ *      the launcher's Parcelable[] of Bundles); they are passed straight to the
+ *      setters, which persist them as JSON.
+ */
+
+import { StorageService } from './storage';
+import { saveSecurePin, securePinMatches } from './secureStorage';
+
+// Must match the fleet's actual configured PIN length so an admin who forgets
+// to quote the value in the console (pushing it as an integer) still gets the
+// correct zero-padded string on-device. Correct quoting remains the primary
+// rule; this padding is only a safety net.
+export const KIOSK_PIN_LENGTH = 6;
+
+const CLEAR_SENTINEL = '__CLEAR__';
+
+type Setter<T> = (value: T) => Promise<void>;
+
+// Native module surface used for the acknowledgement side-channel.
+export interface ManagedConfigNative {
+  reportCustom(slot: number, value: string): Promise<boolean>;
+}
+
+// ---- coercion helpers ------------------------------------------------------
+
+function toBool(v: unknown): boolean {
+  if (typeof v === 'boolean') return v;
+  if (typeof v === 'number') return v !== 0;
+  if (typeof v === 'string') return v === 'true' || v === '1';
+  return false;
+}
+
+function toNum(v: unknown): number | undefined {
+  // Convention 1: numeric strings are first-class here.
+  const n = typeof v === 'number' ? v : Number(v);
+  return Number.isFinite(n) ? n : undefined;
+}
+
+function toStr(v: unknown): string {
+  return v == null ? '' : String(v);
+}
+
+/** Convention 2: resolve the ["__CLEAR__"] sentinel to a real empty array. */
+function resolveList<T>(v: unknown): T[] | undefined {
+  if (!Array.isArray(v)) return undefined;
+  if (v.length === 1 && v[0] === CLEAR_SENTINEL) return [];
+  return v as T[];
+}
+
+// ---- apply table -----------------------------------------------------------
+//
+// Grouped by value type to stay mechanical. Each entry maps a managedConfig
+// JSON key to the StorageService setter it drives. Enum-valued setters are in
+// the string group; the setters themselves validate/narrow.
+//
+// Deliberately excluded (per plan): rest_api_key, mqtt_password,
+// http_basic_auth_password (secrets stay GUI-only), and kiosk_pin (handled by
+// applyPin, out-of-band from config_version gating).
+
+const BOOL_FIELDS: Record<string, Setter<boolean>> = {
+  auto_reload: StorageService.saveAutoReload,
+  kiosk_enabled: StorageService.saveKioskEnabled,
+  auto_launch: StorageService.saveAutoLaunch,
+  screensaver_enabled: StorageService.saveScreensaverEnabled,
+  screensaver_video_loop: StorageService.saveScreensaverVideoLoop,
+  screensaver_motion_enabled: StorageService.saveScreensaverMotionEnabled,
+  auto_relaunch_app: StorageService.saveAutoRelaunchApp,
+  overlay_button_visible: StorageService.saveOverlayButtonVisible,
+  status_bar_enabled: StorageService.saveStatusBarEnabled,
+  status_bar_on_overlay: StorageService.saveStatusBarOnOverlay,
+  status_bar_on_return: StorageService.saveStatusBarOnReturn,
+  status_bar_show_battery: StorageService.saveStatusBarShowBattery,
+  status_bar_show_wifi: StorageService.saveStatusBarShowWifi,
+  status_bar_show_bluetooth: StorageService.saveStatusBarShowBluetooth,
+  status_bar_show_volume: StorageService.saveStatusBarShowVolume,
+  status_bar_show_time: StorageService.saveStatusBarShowTime,
+  battery_lock_enabled: StorageService.saveBatteryLockEnabled,
+  url_rotation_enabled: StorageService.saveUrlRotationEnabled,
+  url_planner_enabled: StorageService.saveUrlPlannerEnabled,
+  rest_api_enabled: StorageService.saveRestApiEnabled,
+  rest_api_allow_control: StorageService.saveRestApiAllowControl,
+  allow_power_button: StorageService.saveAllowPowerButton,
+  allow_notifications: StorageService.saveAllowNotifications,
+  allow_system_info: StorageService.saveAllowSystemInfo,
+  volume_up_5tap_enabled: StorageService.saveVolumeUp5TapEnabled,
+  blocking_overlays_enabled: StorageService.saveBlockingOverlaysEnabled,
+  webview_back_button_enabled: StorageService.saveWebViewBackButtonEnabled,
+  auto_brightness_enabled: StorageService.saveAutoBrightnessEnabled,
+  brightness_management_enabled: StorageService.saveBrightnessManagementEnabled,
+  screen_scheduler_enabled: StorageService.saveScreenSchedulerEnabled,
+  screen_scheduler_wake_on_touch: StorageService.saveScreenSchedulerWakeOnTouch,
+  keep_screen_on: StorageService.saveKeepScreenOn,
+  auto_wake_on_screen_off: StorageService.saveAutoWakeOnScreenOff,
+  inactivity_return_enabled: StorageService.saveInactivityReturnEnabled,
+  inactivity_return_reset_on_nav: StorageService.saveInactivityReturnResetOnNav,
+  inactivity_return_clear_cache: StorageService.saveInactivityReturnClearCache,
+  inactivity_return_scroll_top: StorageService.saveInactivityReturnScrollTop,
+  url_filter_enabled: StorageService.saveUrlFilterEnabled,
+  url_filter_show_feedback: StorageService.saveUrlFilterShowFeedback,
+  pdf_viewer_enabled: StorageService.savePdfViewerEnabled,
+  print_enabled: StorageService.savePrintEnabled,
+  disable_user_zoom: StorageService.saveDisableUserZoom,
+  mqtt_enabled: StorageService.saveMqttEnabled,
+  mqtt_allow_control: StorageService.saveMqttAllowControl,
+  mqtt_motion_always_on: StorageService.saveMqttMotionAlwaysOn,
+  beta_updates_enabled: StorageService.saveBetaUpdatesEnabled,
+  dashboard_mode_enabled: StorageService.saveDashboardModeEnabled,
+  media_player_autoplay: StorageService.saveMediaPlayerAutoPlay,
+  media_player_loop: StorageService.saveMediaPlayerLoop,
+  media_player_shuffle: StorageService.saveMediaPlayerShuffle,
+  media_player_show_controls: StorageService.saveMediaPlayerShowControls,
+  media_player_transition: StorageService.saveMediaPlayerTransition,
+  media_player_mute: StorageService.saveMediaPlayerMute,
+};
+
+// String + enum fields. Enum setters are typed narrower than string; the cast
+// is safe because the setter validates and this is an external-config boundary.
+const STRING_FIELDS: Record<string, Setter<string>> = {
+  url: StorageService.saveUrl,
+  display_mode: StorageService.saveDisplayMode as Setter<string>,
+  external_app_package: StorageService.saveExternalAppPackage,
+  external_app_mode: StorageService.saveExternalAppMode as Setter<string>,
+  pin_mode: StorageService.savePinMode as Setter<string>,
+  keyboard_mode: StorageService.saveKeyboardMode,
+  back_button_mode: StorageService.saveBackButtonMode,
+  return_mode: StorageService.saveReturnMode,
+  return_button_position: StorageService.saveReturnButtonPosition,
+  status_bar_theme: StorageService.saveStatusBarTheme as Setter<string>,
+  screensaver_type: StorageService.saveScreensaverType as Setter<string>,
+  screensaver_url: StorageService.saveScreensaverUrl,
+  motion_camera_position: StorageService.saveMotionCameraPosition as Setter<string>,
+  screensaver_motion_sensitivity: StorageService.saveScreensaverMotionSensitivity,
+  url_filter_mode: StorageService.saveUrlFilterMode,
+  print_paper_size: StorageService.savePrintPaperSize,
+  custom_user_agent: StorageService.saveCustomUserAgent,
+  battery_lock_message: StorageService.saveBatteryLockMessage,
+  mqtt_broker_url: StorageService.saveMqttBrokerUrl,
+  mqtt_username: StorageService.saveMqttUsername,
+  mqtt_client_id: StorageService.saveMqttClientId,
+  mqtt_base_topic: StorageService.saveMqttBaseTopic,
+  mqtt_discovery_prefix: StorageService.saveMqttDiscoveryPrefix,
+  mqtt_device_name: StorageService.saveMqttDeviceName,
+  media_player_fit_mode: StorageService.saveMediaPlayerFitMode as Setter<string>,
+  media_player_bg_color: StorageService.saveMediaPlayerBgColor,
+  http_basic_auth_username: StorageService.saveHttpBasicAuthUsername,
+};
+
+const NUMBER_FIELDS: Record<string, Setter<number>> = {
+  pin_max_attempts: StorageService.savePinMaxAttempts,
+  back_button_timer_delay: StorageService.saveBackButtonTimerDelay,
+  url_rotation_interval: StorageService.saveUrlRotationInterval,
+  rest_api_port: StorageService.saveRestApiPort,
+  return_tap_count: StorageService.saveReturnTapCount,
+  return_tap_timeout: StorageService.saveReturnTapTimeout,
+  screensaver_brightness: StorageService.saveScreensaverBrightness,
+  screensaver_inactivity_delay: StorageService.saveScreensaverInactivityDelay,
+  default_brightness: StorageService.saveDefaultBrightness,
+  battery_lock_threshold: StorageService.saveBatteryLockThreshold,
+  battery_warn_threshold: StorageService.saveBatteryWarnThreshold,
+  battery_release_threshold: StorageService.saveBatteryReleaseThreshold,
+  battery_warn_step: StorageService.saveBatteryWarnStep,
+  webview_back_button_x_percent: StorageService.saveWebViewBackButtonXPercent,
+  webview_back_button_y_percent: StorageService.saveWebViewBackButtonYPercent,
+  auto_brightness_min: StorageService.saveAutoBrightnessMin,
+  auto_brightness_max: StorageService.saveAutoBrightnessMax,
+  auto_brightness_offset: StorageService.saveAutoBrightnessOffset,
+  inactivity_return_delay: StorageService.saveInactivityReturnDelay,
+  webview_zoom_level: StorageService.saveWebViewZoomLevel,
+  mqtt_port: StorageService.saveMqttPort,
+  mqtt_status_interval: StorageService.saveMqttStatusInterval,
+  media_player_image_duration: StorageService.saveMediaPlayerImageDuration,
+  media_player_transition_duration: StorageService.saveMediaPlayerTransitionDuration,
+};
+
+// Array / object-array fields (convention 2 + 4). Typed loosely as unknown[]
+// since the setters each expect their own element shape; the console-authored
+// JSON is responsible for matching those shapes.
+const ARRAY_FIELDS: Record<string, Setter<any[]>> = {
+  url_rotation_list: StorageService.saveUrlRotationList,
+  url_planner_events: StorageService.saveUrlPlannerEvents,
+  blocking_overlays_regions: StorageService.saveBlockingOverlaysRegions,
+  screen_scheduler_rules: StorageService.saveScreenSchedulerRules,
+  url_filter_list: StorageService.saveUrlFilterList,
+  managed_apps: StorageService.saveManagedApps,
+  screensaver_video_items: StorageService.saveScreensaverVideoItems,
+  media_player_items: StorageService.saveMediaPlayerItems,
+  dashboard_tiles: StorageService.saveDashboardTiles,
+};
+
+// ---- PIN (convention 3) ----------------------------------------------------
+
+/**
+ * Apply a top-level kiosk_pin sibling attribute. Runs on EVERY emission,
+ * ungated by config_version. Idempotent: only writes (and acks) on a real
+ * change. Never reports anything derived from the PIN — the ack is the
+ * admin-chosen kiosk_pin_label (or a timestamp fallback).
+ *
+ * Returns true only if the PIN was actually changed.
+ */
+export async function applyPin(
+  restrictions: Record<string, unknown>,
+  native: ManagedConfigNative | undefined,
+): Promise<boolean> {
+  const rawPin = restrictions.kiosk_pin;
+  if (rawPin === undefined || rawPin === null) return false;
+
+  const pin = String(rawPin).padStart(KIOSK_PIN_LENGTH, '0');
+  const unchanged = await securePinMatches(pin);
+  if (unchanged) {
+    console.log('[ManagedConfig] kiosk_pin present but unchanged; skipping');
+    return false;
+  }
+
+  await saveSecurePin(pin);
+
+  // Ack token: the admin-pushed kiosk_pin_label if present, otherwise a
+  // human-readable local "applied at" datetime (never raw epoch ms, and never
+  // anything derived from the PIN itself).
+  const label = restrictions.kiosk_pin_label;
+  const ackValue = label != null ? String(label) : formatLocalDateTime(new Date());
+  try {
+    await native?.reportCustom(2, ackValue);
+    console.log(`[ManagedConfig] PIN updated, reported ack custom2=${ackValue}`);
+  } catch (e) {
+    console.warn('[ManagedConfig] PIN ack (custom2) failed:', e);
+  }
+  return true;
+}
+
+/** Local time as "YYYY-MM-DD HH:mm" — sortable in the console's custom2 column. */
+function formatLocalDateTime(d: Date): string {
+  const pad = (n: number) => String(n).padStart(2, '0');
+  return (
+    `${d.getFullYear()}-${pad(d.getMonth() + 1)}-${pad(d.getDate())} ` +
+    `${pad(d.getHours())}:${pad(d.getMinutes())}`
+  );
+}
+
+// ---- bulk apply (version-gated) --------------------------------------------
+
+/**
+ * Apply the managedConfig blob's fields. Assumes the caller has already decided
+ * config_version changed. Returns true if at least one field was written.
+ */
+async function applyBulk(managedConfig: Record<string, unknown>): Promise<boolean> {
+  let changed = false;
+
+  for (const [key, setter] of Object.entries(BOOL_FIELDS)) {
+    if (key in managedConfig) {
+      await setter(toBool(managedConfig[key]));
+      changed = true;
+    }
+  }
+  for (const [key, setter] of Object.entries(STRING_FIELDS)) {
+    if (key in managedConfig) {
+      await setter(toStr(managedConfig[key]));
+      changed = true;
+    }
+  }
+  for (const [key, setter] of Object.entries(NUMBER_FIELDS)) {
+    if (key in managedConfig) {
+      const n = toNum(managedConfig[key]);
+      if (n !== undefined) {
+        await setter(n);
+        changed = true;
+      } else {
+        console.warn(`[ManagedConfig] ${key}: not a finite number, skipped`, managedConfig[key]);
+      }
+    }
+  }
+  for (const [key, setter] of Object.entries(ARRAY_FIELDS)) {
+    if (key in managedConfig) {
+      const list = resolveList(managedConfig[key]);
+      if (list !== undefined) {
+        await setter(list);
+        changed = true;
+      } else {
+        console.warn(`[ManagedConfig] ${key}: not an array, skipped`, managedConfig[key]);
+      }
+    }
+  }
+
+  return changed;
+}
+
+export interface ApplyResult {
+  /** PIN was changed (never triggers a reload). */
+  pinChanged: boolean;
+  /** Bulk config_version changed and fields were applied (may trigger reload). */
+  bulkApplied: boolean;
+}
+
+/**
+ * Top-level entry: apply an incoming restrictions bundle.
+ *
+ * `restrictions` is the whole App Restrictions object as read by the native
+ * module. IMPORTANT: the Headwind launcher FLATTENS the `managedConfig`
+ * attribute's JSON keys directly into the top level of this bundle (see
+ * AppRestrictionUpdater.parseManagedConfig on the launcher side) — there is no
+ * nested `managedConfig` object on the device. So `config_version`, every
+ * setting key, and the PIN siblings (`kiosk_pin`, `kiosk_pin_label`) all live
+ * directly on `restrictions`.
+ */
+export async function applyManagedConfig(
+  restrictions: Record<string, unknown> | null | undefined,
+  native: ManagedConfigNative | undefined,
+): Promise<ApplyResult> {
+  const result: ApplyResult = { pinChanged: false, bulkApplied: false };
+  if (!restrictions) {
+    console.log('[ManagedConfig] no restrictions bundle; nothing to apply');
+    return result;
+  }
+  console.log('[ManagedConfig] restrictions received, keys=', Object.keys(restrictions));
+
+  // 1. PIN — ungated, every emission (top-level kiosk_pin).
+  try {
+    result.pinChanged = await applyPin(restrictions, native);
+  } catch (e) {
+    console.warn('[ManagedConfig] applyPin failed:', e);
+  }
+
+  // 2 + 3. Bulk config, gated on config_version — read from the TOP LEVEL of
+  // the (flattened) restrictions bundle, not a nested object.
+  const incomingVersion =
+    restrictions.config_version !== undefined && restrictions.config_version !== null
+      ? String(restrictions.config_version)
+      : undefined;
+
+  if (incomingVersion === undefined) {
+    console.log('[ManagedConfig] no config_version present; skipping bulk apply (PIN-only or empty push)');
+    return result;
+  }
+
+  const lastVersion = await StorageService.getManagedConfigVersion();
+  console.log(`[ManagedConfig] config_version incoming=${incomingVersion} last=${lastVersion ?? '(none)'}`);
+  if (incomingVersion === lastVersion) {
+    console.log('[ManagedConfig] config_version unchanged; skipping bulk apply');
+    return result;
+  }
+
+  const changed = await applyBulk(restrictions);
+  await StorageService.saveManagedConfigVersion(incomingVersion);
+  result.bulkApplied = changed;
+  console.log(`[ManagedConfig] bulk apply done, changed=${changed}`);
+
+  // Ack on every version advance (even changed===false), so the console's
+  // custom1 column reliably reflects "device picked up version N".
+  if (native) {
+    try {
+      await native.reportCustom(1, incomingVersion);
+      console.log(`[ManagedConfig] reported config ack custom1=${incomingVersion}`);
+    } catch (e) {
+      console.warn('[ManagedConfig] config_version ack (custom1) failed:', e);
+    }
+  }
+
+  return result;
+}
