+  // ==================== PATCH patch_keyboard_fix (see onCreate) ====================
+  // Self-healing IME bottom padding for API < 30. Replaces patch_keyboard_gap.
+
+  private val imeWatchdogHandler = Handler(Looper.getMainLooper())
+  private var imeWatchdogRunning = false
+
+  private fun installImeInsetsHandling() {
+    val contentView = findViewById<View>(android.R.id.content)
+    val fixEnabled = getSharedPreferences("FreeKioskSettings", Context.MODE_PRIVATE)
+      .getBoolean("patch_keyboard_fix_enabled", true)
+
+    ViewCompat.setOnApplyWindowInsetsListener(contentView) { view, insets ->
+      val imeBottom = insets.getInsets(WindowInsetsCompat.Type.ime()).bottom
+      if (fixEnabled) {
+        applyImeBottomPadding(imeBottom, "insets-dispatch")
+      } else {
+        // Patch OFF: exact upstream v1.2.19 behavior.
+        view.setPadding(0, 0, 0, imeBottom)
+      }
+      insets
+    }
+
+    // The self-heal mechanisms are only needed where the resting insets
+    // dispatch after IME-hide can go missing (observed on Android 10 /
+    // Kyocera DuraForce2). API 30+ delivers IME insets reliably.
+    if (fixEnabled && Build.VERSION.SDK_INT < Build.VERSION_CODES.R) {
+      window.decorView.viewTreeObserver.addOnGlobalLayoutListener {
+        applyImeBottomPadding(computeImeCoverage(), "global-layout")
+      }
+    }
+  }
+
+  /**
+   * Screen area covered by the IME, computed from the window's visible display
+   * frame — available on every layout pass, independent of insets dispatch.
+   * Coverage below 15% of the root height is treated as "no keyboard" so
+   * transient system-bar insets can't masquerade as one (same heuristic React
+   * Native's ReactRootView uses for its keyboard events).
+   */
+  private fun computeImeCoverage(): Int {
+    val decor = window.decorView
+    val rootHeight = decor.rootView.height
+    if (rootHeight <= 0) return 0
+    val visible = android.graphics.Rect()
+    decor.getWindowVisibleDisplayFrame(visible)
+    val covered = rootHeight - visible.bottom
+    return if (covered > rootHeight * 0.15f) covered else 0
+  }
+
+  private fun applyImeBottomPadding(bottom: Int, source: String) {
+    val contentView = findViewById<View>(android.R.id.content)
+    if (contentView.paddingBottom != bottom) {
+      android.util.Log.i("FreeKioskIME", "bottom padding ${contentView.paddingBottom} -> $bottom ($source)")
+      contentView.setPadding(0, 0, 0, bottom)
+    }
+    if (bottom > 0 && Build.VERSION.SDK_INT < Build.VERSION_CODES.R) {
+      startImeWatchdog()
+    }
+  }
+
+  // While keyboard padding is applied, periodically force an insets + layout
+  // round-trip with the WindowManager. On devices that never deliver the
+  // IME-hidden insets (the white-band bug) this is the programmatic equivalent
+  // of the events observed to heal the screen — opening the power menu or a
+  // Settings round-trip — so a stale state self-corrects within ~1s. Stops as
+  // soon as the padding is back to 0, so it costs nothing in steady state; and
+  // while the IME is genuinely open the WindowManager keeps reporting the
+  // reduced visible frame, so it cannot oscillate.
+  private fun startImeWatchdog() {
+    if (imeWatchdogRunning) return
+    imeWatchdogRunning = true
+    scheduleImeWatchdogTick()
+  }
+
+  private fun scheduleImeWatchdogTick() {
+    imeWatchdogHandler.postDelayed({
+      val contentView = findViewById<View>(android.R.id.content)
+      if (contentView.paddingBottom <= 0) {
+        imeWatchdogRunning = false
+        return@postDelayed
+      }
+      val covered = computeImeCoverage()
+      if (covered != contentView.paddingBottom) {
+        android.util.Log.i(
+          "FreeKioskIME",
+          "watchdog corrected stale padding ${contentView.paddingBottom} -> $covered"
+        )
+        contentView.setPadding(0, 0, 0, covered)
+      }
+      ViewCompat.requestApplyInsets(contentView)
+      contentView.requestLayout()
+      if (contentView.paddingBottom > 0) {
+        scheduleImeWatchdogTick()
+      } else {
+        imeWatchdogRunning = false
+      }
+    }, 500L)
+  }
+  // ==================== END PATCH patch_keyboard_fix ====================
