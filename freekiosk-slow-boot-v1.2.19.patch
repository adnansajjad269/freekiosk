diff --git a/android/app/src/main/java/com/freekiosk/BootReceiver.kt b/android/app/src/main/java/com/freekiosk/BootReceiver.kt
index e7d624d..a5b2c47 100644
--- a/android/app/src/main/java/com/freekiosk/BootReceiver.kt
+++ b/android/app/src/main/java/com/freekiosk/BootReceiver.kt
@@ -132,7 +132,15 @@ class BootReceiver : BroadcastReceiver() {
             val isDeviceOwner = dpm.isDeviceOwnerApp(context.packageName)
             val kioskEnabled = isKioskEnabled(context)
             DebugLog.d("BootReceiver", "Fast boot-lock check: DO=$isDeviceOwner, kiosk=$kioskEnabled")
-            isDeviceOwner && kioskEnabled
+            // Fire the instant native boot splash (BootLockActivity) whenever kiosk
+            // mode is enabled, even if FreeKiosk is NOT itself the Device Owner. On
+            // Headwind MDM fleets the launcher is the Device Owner, so the old
+            // `isDeviceOwner && kioskEnabled` gate was always false and the splash
+            // never showed — leaving the slow ~10-15s RN cold start visible on boot.
+            // The BootLockActivity launch below is wrapped in try/catch and falls
+            // back to launchMainActivityLegacy() if a background activity-launch
+            // restriction blocks it, so relaxing the gate cannot regress boot.
+            kioskEnabled
         } catch (e: Exception) {
             false
         }
diff --git a/android/app/src/main/java/com/freekiosk/MainActivity.kt b/android/app/src/main/java/com/freekiosk/MainActivity.kt
index a668ed0..5afe18f 100644
--- a/android/app/src/main/java/com/freekiosk/MainActivity.kt
+++ b/android/app/src/main/java/com/freekiosk/MainActivity.kt
@@ -79,8 +79,17 @@ class MainActivity : ReactActivity() {
   override fun onCreate(savedInstanceState: Bundle?) {
     super.onCreate(null)
 
-    // Keep screen always on
-    window.addFlags(WindowManager.LayoutParams.FLAG_KEEP_SCREEN_ON)
+    // Keep screen on only when the "Keep Screen On" setting is enabled (default
+    // true). Previously this flag was added unconditionally on every onCreate,
+    // so it was re-pinned on every activity (re)creation and raced loadSettings()
+    // trying to clear it — making the screen stay on even when the setting was
+    // OFF. Reading the persisted pref here (same store KioskModule.setKeepScreenOn
+    // writes) makes the setting authoritative from the first frame.
+    val keepScreenOnPref = getSharedPreferences("FreeKioskSettings", Context.MODE_PRIVATE)
+        .getBoolean("keep_screen_on", true)
+    if (keepScreenOnPref) {
+        window.addFlags(WindowManager.LayoutParams.FLAG_KEEP_SCREEN_ON)
+    }
 
     // Extend content into display cutout areas to prevent OEM chrome from appearing (#94)
     if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.P) {
diff --git a/src/components/WebViewComponent.tsx b/src/components/WebViewComponent.tsx
index 290b5b8..6635757 100644
--- a/src/components/WebViewComponent.tsx
+++ b/src/components/WebViewComponent.tsx
@@ -597,6 +597,38 @@ const WebViewComponent = forwardRef<WebViewComponentRef, WebViewComponentProps>(
       `;
     }
 
+    if (keyboardMode === 'force_text') {
+      // Force a consistent ALPHABETIC keyboard on every text-like field, so
+      // e.g. an email field and a password field on the same login form present
+      // the same keyboard instead of the website/OS choosing different ones per
+      // field. Explicitly-numeric fields (type number/tel, or inputmode
+      // numeric/decimal/tel — e.g. an OTP box) are left untouched. Password
+      // fields stay masked (their type is not changed; only inputmode is set).
+      return `
+        (function() {
+          function forceTextKeyboard() {
+            const fields = document.querySelectorAll('input, textarea');
+            fields.forEach(function(input) {
+              const type = (input.type || '').toLowerCase();
+              const inputmode = (input.getAttribute('inputmode') || '').toLowerCase();
+              const isNumeric = type === 'number' || type === 'tel' ||
+                inputmode === 'numeric' || inputmode === 'decimal' || inputmode === 'tel';
+              if (type === 'hidden' || type === 'submit' || type === 'button' ||
+                  type === 'checkbox' || type === 'radio' || isNumeric) {
+                return;
+              }
+              input.setAttribute('inputmode', 'text');
+            });
+          }
+
+          forceTextKeyboard();
+
+          const observer = new MutationObserver(forceTextKeyboard);
+          observer.observe(document.body, { childList: true, subtree: true });
+        })();
+      `;
+    }
+
     return '';
   };
 
