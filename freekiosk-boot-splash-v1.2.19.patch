diff --git a/android/app/src/main/java/com/freekiosk/BootReceiver.kt b/android/app/src/main/java/com/freekiosk/BootReceiver.kt
index e7d624d..0868e0b 100644
--- a/android/app/src/main/java/com/freekiosk/BootReceiver.kt
+++ b/android/app/src/main/java/com/freekiosk/BootReceiver.kt
@@ -131,8 +131,21 @@ class BootReceiver : BroadcastReceiver() {
             val dpm = context.getSystemService(Context.DEVICE_POLICY_SERVICE) as DevicePolicyManager
             val isDeviceOwner = dpm.isDeviceOwnerApp(context.packageName)
             val kioskEnabled = isKioskEnabled(context)
-            DebugLog.d("BootReceiver", "Fast boot-lock check: DO=$isDeviceOwner, kiosk=$kioskEnabled")
-            isDeviceOwner && kioskEnabled
+            // PATCH patch_boot_splash (default ON, ADB-toggleable): fire the
+            // instant native boot splash (BootLockActivity) whenever kiosk mode is
+            // enabled, even if FreeKiosk is NOT itself the Device Owner. On
+            // Headwind MDM fleets the launcher is the Device Owner, so the old
+            // `isDeviceOwner && kioskEnabled` gate was always false and the splash
+            // never showed — leaving the slow ~10-15s RN cold start visible on
+            // boot. The BootLockActivity launch is wrapped in try/catch and falls
+            // back to launchMainActivityLegacy() if a background activity-launch
+            // restriction blocks it, so relaxing the gate cannot regress boot.
+            // When the patch is OFF, restore the original device-owner gate.
+            val bootSplashPatch = context
+                .getSharedPreferences("FreeKioskSettings", Context.MODE_PRIVATE)
+                .getBoolean("patch_boot_splash_enabled", true)
+            DebugLog.d("BootReceiver", "Fast boot-lock check: DO=$isDeviceOwner, kiosk=$kioskEnabled, patch=$bootSplashPatch")
+            if (bootSplashPatch) kioskEnabled else isDeviceOwner && kioskEnabled
         } catch (e: Exception) {
             false
         }
