             promise.reject("ERROR", "bringToFront failed: ${e.message}")
         }
     }
+
+    /**
+     * Force the system default keyboard (IME) so every field on the LAAM page
+     * presents the same keyboard, instead of each field getting whatever IME the
+     * OS last used. The device-side `force_text` WebView hack fought the site and
+     * was glitchy; enforcing one IME is the robust fix.
+     *
+     * `target`:
+     *   ""/"system" -> no-op (leave whatever the OS default is).
+     *   "gboard"    -> resolve and enforce Google Keyboard
+     *                  (package com.google.android.inputmethod.latin).
+     *   anything else -> treated as an IME id or package-name prefix to match.
+     *
+     * Uses WRITE_SECURE_SETTINGS (same permission/pattern AccessibilityModule
+     * uses to enable its service): append the IME id to ENABLED_INPUT_METHODS if
+     * missing, then set DEFAULT_INPUT_METHOD to it. If the target IME isn't
+     * installed or the permission isn't granted, we log a warning and resolve
+     * without changing anything — never crash the kiosk over a keyboard.
+     */
+    @ReactMethod
+    fun setDefaultKeyboard(target: String, promise: Promise) {
+        try {
+            val want = target.trim()
+            if (want.isEmpty() || want.equals("system", ignoreCase = true)) {
+                android.util.Log.d("KioskModule", "setDefaultKeyboard: no-op (system default)")
+                promise.resolve("system")
+                return
+            }
+
+            // Map friendly alias -> package prefix used to match against the
+            // installed IME list.
+            val matchPrefix = if (want.equals("gboard", ignoreCase = true))
+                "com.google.android.inputmethod.latin" else want
+
+            val imm = reactApplicationContext
+                .getSystemService(Context.INPUT_METHOD_SERVICE) as android.view.inputmethod.InputMethodManager
+            val installed = imm.inputMethodList
+            // Prefer an exact id match, else match by package/id prefix.
+            val ime = installed.firstOrNull { it.id == want }
+                ?: installed.firstOrNull { it.id.contains(matchPrefix) || it.packageName == matchPrefix }
+
+            if (ime == null) {
+                android.util.Log.w("KioskModule",
+                    "setDefaultKeyboard: IME matching '$want' not installed — leaving current default")
+                promise.resolve("not_found")
+                return
+            }
+
+            val imeId = ime.id
+            val resolver = reactApplicationContext.contentResolver
+
+            // 1) Ensure it's in the enabled list (can't be default if disabled).
+            val enabled = android.provider.Settings.Secure.getString(
+                resolver, android.provider.Settings.Secure.ENABLED_INPUT_METHODS
+            ) ?: ""
+            val already = enabled.split(":").any { it == imeId }
+            if (!already) {
+                val newEnabled = if (enabled.isEmpty()) imeId else "$enabled:$imeId"
+                android.provider.Settings.Secure.putString(
+                    resolver, android.provider.Settings.Secure.ENABLED_INPUT_METHODS, newEnabled
+                )
+            }
+
+            // 2) Make it the default.
+            val current = android.provider.Settings.Secure.getString(
+                resolver, android.provider.Settings.Secure.DEFAULT_INPUT_METHOD
+            )
+            if (current != imeId) {
+                android.provider.Settings.Secure.putString(
+                    resolver, android.provider.Settings.Secure.DEFAULT_INPUT_METHOD, imeId
+                )
+                android.util.Log.d("KioskModule", "setDefaultKeyboard: default IME set to $imeId")
+            } else {
+                android.util.Log.d("KioskModule", "setDefaultKeyboard: $imeId already default")
+            }
+            promise.resolve(imeId)
+        } catch (se: SecurityException) {
+            android.util.Log.w("KioskModule",
+                "setDefaultKeyboard: WRITE_SECURE_SETTINGS not granted (${se.message}) — leaving current default")
+            // Resolve (not reject) so a missing grant never breaks config apply.
+            promise.resolve("permission_denied")
+        } catch (e: Exception) {
+            android.util.Log.e("KioskModule", "setDefaultKeyboard failed: ${e.message}")
+            promise.resolve("error")
+        }
+    }
 }
