+// #1 — When "Keep Screen On" is OFF the user expects the OS screen timeout to
+// put the display to sleep. But the LAAM web app holds a Screen Wake Lock
+// (navigator.wakeLock), which the Chromium WebView honors and which keeps the
+// screen awake regardless of the window flag we clear natively. This script
+// neutralizes it: it stubs navigator.wakeLock.request so any lock the page asks
+// for is returned already-released (the system is never actually held awake),
+// and releases anything currently held. The original request fn is stashed on
+// window.__fkWakeOrig so it can be restored if the setting is turned back on.
+// Ends with `true;` to silence react-native-webview's injection warning.
+const WAKE_LOCK_NEUTRALIZE_JS = `
+(function(){
+  try {
+    if (!('wakeLock' in navigator)) return;
+    if (!window.__fkWakeOrig) {
+      window.__fkWakeOrig = navigator.wakeLock.request.bind(navigator.wakeLock);
+    }
+    if (window.__fkWakeSentinels) {
+      window.__fkWakeSentinels.forEach(function(s){ try { s.release && s.release(); } catch(e){} });
+    }
+    window.__fkWakeSentinels = [];
+    navigator.wakeLock.request = function(){
+      var listeners = [];
+      var sentinel = {
+        released: true, type: 'screen', onrelease: null,
+        release: function(){ return Promise.resolve(); },
+        addEventListener: function(t, cb){ if (t === 'release') listeners.push(cb); },
+        removeEventListener: function(t, cb){ listeners = listeners.filter(function(l){ return l !== cb; }); }
+      };
+      setTimeout(function(){
+        listeners.forEach(function(cb){ try { cb(); } catch(e){} });
+        if (sentinel.onrelease) { try { sentinel.onrelease(); } catch(e){} }
+      }, 0);
+      return Promise.resolve(sentinel);
+    };
+  } catch(e){}
+})();
+true;
+`;
+
+// Restore the real navigator.wakeLock.request (used when "Keep Screen On" is
+// switched back ON without a page reload).
+const WAKE_LOCK_RESTORE_JS = `
+(function(){
+  try {
+    if (window.__fkWakeOrig && ('wakeLock' in navigator)) {
+      navigator.wakeLock.request = window.__fkWakeOrig;
+    }
+  } catch(e){}
+})();
+true;
+`;
