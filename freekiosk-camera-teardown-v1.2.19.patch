+// #camera-teardown diagnostics: log every getUserMedia call and failure (error
+// name + message + duration) so camera-start failures on device are visible via
+// `adb logcat` (ReactNativeJS tag). Log-only — no retry, no behavior change.
+// Installed at document start so it wraps before any page script runs.
+const CAMERA_DIAG_JS = `
+(function(){
+  try {
+    if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) return;
+    if (navigator.mediaDevices.__fkCamDiag) return;
+    navigator.mediaDevices.__fkCamDiag = true;
+    var orig = navigator.mediaDevices.getUserMedia.bind(navigator.mediaDevices);
+    navigator.mediaDevices.getUserMedia = function(constraints){
+      var t0 = Date.now();
+      try { console.log('[FreeKioskCam] getUserMedia start ' + JSON.stringify(constraints)); } catch(e) {}
+      return orig(constraints).then(function(stream){
+        console.log('[FreeKioskCam] getUserMedia OK in ' + (Date.now()-t0) + 'ms');
+        return stream;
+      }, function(err){
+        console.log('[FreeKioskCam] getUserMedia FAILED in ' + (Date.now()-t0) + 'ms: ' + (err && err.name) + ' - ' + (err && err.message));
+        throw err;
+      });
+    };
+  } catch(e){}
+})();
+true;
+`;
