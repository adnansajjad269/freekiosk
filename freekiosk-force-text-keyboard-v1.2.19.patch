@@ -597,6 +607,40 @@ const WebViewComponent = forwardRef<WebViewComponentRef, WebViewComponentProps>(
       `;
     }
 
+    if (keyboardMode === 'force_text' && forceTextPatchEnabled) {
+      // PATCH patch_force_text: force a consistent ALPHABETIC keyboard on every
+      // text-like field, so e.g. an email field and a password field on the same
+      // login form present the same keyboard instead of the website/OS choosing
+      // different ones per field. Explicitly-numeric fields (type number/tel, or
+      // inputmode numeric/decimal/tel — e.g. an OTP box) are left untouched.
+      // Password fields stay masked (their type is not changed; only inputmode is
+      // set). When the patch flag is OFF this branch is skipped (behaves like
+      // 'default').
+      return `
+        (function() {
+          function forceTextKeyboard() {
+            const fields = document.querySelectorAll('input, textarea');
+            fields.forEach(function(input) {
+              const type = (input.type || '').toLowerCase();
+              const inputmode = (input.getAttribute('inputmode') || '').toLowerCase();
+              const isNumeric = type === 'number' || type === 'tel' ||
+                inputmode === 'numeric' || inputmode === 'decimal' || inputmode === 'tel';
+              if (type === 'hidden' || type === 'submit' || type === 'button' ||
+                  type === 'checkbox' || type === 'radio' || isNumeric) {
+                return;
+              }
+              input.setAttribute('inputmode', 'text');
+            });
+          }
+
+          forceTextKeyboard();
+
+          const observer = new MutationObserver(forceTextKeyboard);
+          observer.observe(document.body, { childList: true, subtree: true });
+        })();
+      `;
+    }
+
     return '';
   };
 
