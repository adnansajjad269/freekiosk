+    var imeWasVisible = false
+
+    fun forceContentRelayout() {
+      val target = (contentView as? ViewGroup)?.getChildAt(0) ?: contentView
+      val lp = target.layoutParams ?: return
+      val currentHeight = target.height
+      if (currentHeight <= 0) return
+      val originalLpHeight = lp.height
+      lp.height = currentHeight - 1
+      target.layoutParams = lp
+      target.post {
+        lp.height = originalLpHeight
+        target.layoutParams = lp
+        target.requestLayout()
+      }
+    }
+
+    fun applyImePadding(view: View, insets: WindowInsetsCompat, allowRelayoutKick: Boolean) {
+      val imeVisible = insets.isVisible(WindowInsetsCompat.Type.ime())
+      val bottom = if (imeVisible) insets.getInsets(WindowInsetsCompat.Type.ime()).bottom else 0
+      if (view.paddingBottom != bottom) {
+        view.setPadding(0, 0, 0, bottom)
+        view.requestLayout()
+      }
+      if (allowRelayoutKick) {
+        if (imeWasVisible && !imeVisible) {
+          view.post { forceContentRelayout() }
+        }
+        imeWasVisible = imeVisible
+      }
+    }
