-      insets
+    val keyboardGapEnabled = getSharedPreferences("FreeKioskSettings", Context.MODE_PRIVATE)
+        .getBoolean("patch_keyboard_gap_enabled", true)
+
+    if (!keyboardGapEnabled) {
+      ViewCompat.setOnApplyWindowInsetsListener(contentView) { view, insets ->
+        val imeInsets = insets.getInsets(WindowInsetsCompat.Type.ime())
+        view.setPadding(0, 0, 0, imeInsets.bottom)
+        insets
+      }
+    } else {
+      var imeWasVisible = false
+
+      fun forceContentRelayout() {
+        val target = (contentView as? ViewGroup)?.getChildAt(0) ?: contentView
+        val lp = target.layoutParams ?: return
+        val currentHeight = target.height
+        if (currentHeight <= 0) return
+        val originalLpHeight = lp.height
+        lp.height = currentHeight - 1
+        target.layoutParams = lp
+        target.post {
+          lp.height = originalLpHeight
+          target.layoutParams = lp
+          target.requestLayout()
+        }
+      }
