     // Adjust content padding when the soft keyboard appears.
     // In immersive/kiosk mode adjustResize is ignored, so we listen for IME insets
     // and manually add bottom padding so WebView form fields stay visible.
+    //
+    // Bug fix (#keyboard-gap): in immersive/sticky mode the *resting* inset dispatch
+    // is sometimes not delivered when the IME hides, so the keyboard-height bottom
+    // padding was left applied - a white gap the size of the keyboard that only
+    // cleared on a window change (e.g. sleep/wake). Three-part fix:
+    //   1. Explicitly reset padding to 0 when the IME is not visible.
+    //   2. requestLayout() so the child WebView re-measures into the reclaimed space.
+    //   3. Also drive padding from a WindowInsetsAnimation callback, so the value is
+    //      corrected *during* the hide animation even if the final resting dispatch
+    //      is late or missing; onEnd re-applies the true resting insets as a backstop.
     val contentView = findViewById<View>(android.R.id.content)
+
+    fun applyImePadding(view: View, insets: WindowInsetsCompat) {
+      val imeVisible = insets.isVisible(WindowInsetsCompat.Type.ime())
+      val bottom = if (imeVisible) insets.getInsets(WindowInsetsCompat.Type.ime()).bottom else 0
+      if (view.paddingBottom != bottom) {
+        view.setPadding(0, 0, 0, bottom)
+        view.requestLayout()
+      }
+    }
+
     ViewCompat.setOnApplyWindowInsetsListener(contentView) { view, insets ->
-      val imeInsets = insets.getInsets(WindowInsetsCompat.Type.ime())
-      view.setPadding(0, 0, 0, imeInsets.bottom)
+      applyImePadding(view, insets)
       insets
     }
 
+    ViewCompat.setWindowInsetsAnimationCallback(
+      contentView,
+      object : WindowInsetsAnimationCompat.Callback(WindowInsetsAnimationCompat.Callback.DISPATCH_MODE_CONTINUE_ON_SUBTREE) {
+        override fun onProgress(
+          insets: WindowInsetsCompat,
+          runningAnimations: MutableList<WindowInsetsAnimationCompat>
+        ): WindowInsetsCompat {
+          applyImePadding(contentView, insets)
+          return insets
+        }
+
+        override fun onEnd(animation: WindowInsetsAnimationCompat) {
+          ViewCompat.getRootWindowInsets(contentView)?.let { applyImePadding(contentView, it) }
+        }
+      }
+    )
+
     readExternalAppConfig()
     ensureBootReceiverEnabled()
     hideSystemUI()
